# Ignore configuration files that may contain sensitive information
/web/sites/default/settings.php
/web/sites/default/settings.local.php

# Ignore files generated by Drupal and its modules
/web/sites/default/files/*
/web/sites/default/files/
web/sites/default/private/
web/sites/default/temp/

# Ignore files and directories generated by development tools
/web/node_modules/
web/vendor/
web/modules/contrib

# Ignore backup files and directories
*.bak
*.backup
*.swp
*.save
.bak/
.backup/
.swo
.save/

# Ignore Drush configuration files
/drushrc.php
/drush.local.yml

# Ignore IDE-specific files and directories
.idea/
*.iml
*.phpstorm.meta.php
*.sublime-project
*.sublime-workspace

# Ignore log files
*.log

# Ignore user-specific files
.DS_Store
Thumbs.db
ehthumbs.db

# Ignore files generated during development
/build/
/composer.phar
/composer.lock
/drupal.phar

# Ignore Drupal public files
web/sites/default/files/
