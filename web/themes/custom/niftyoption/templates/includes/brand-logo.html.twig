{#
/**
 * @file
 * GrassRed brand logo — full wordmark image.
 *
 * Variables:
 * - logo_size: header | auth | footer (default header)
 * - link_url: Logo link target (default front_page).
 * - modifier: Extra CSS classes on the wrapper link.
 */
#}
{% set brand = niftyoption_brand_name|default(site_name|default('GrassRed')) %}
{% set logo_src = niftyoption_logo_url|default(theme_assets_base|default('/themes/custom/niftyoption') ~ '/assets/images/logo.png?v=' ~ niftyoption_logo_version|default('1')) %}
{% set href = link_url|default(front_page) %}
{% set size = logo_size|default('header') %}
<a href="{{ href }}" class="niftyoption-brand-logo niftyoption-brand-logo--{{ size }} d-inline-flex align-items-center text-decoration-none {{ modifier|default('') }}" aria-label="{{ brand }}">
  <img
    src="{{ logo_src }}"
    class="niftyoption-brand-logo__image"
    alt="{{ brand }}"
    loading="eager"
    decoding="async"
  />
</a>
