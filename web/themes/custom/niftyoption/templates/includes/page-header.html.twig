{#
/**
 * @file
 * Top header bar for the dashboard.
 */
#}
{% set brand_name = niftyoption_brand_name|default(site_name|default('StrikeFlow')) %}
{% set assets_base = theme_assets_base|default('/' ~ directory) %}
<div class="page-header">
  <div class="brand">
    {% include directory ~ '/templates/includes/brand-logo.html.twig' with {
      modifier: 'logo',
      icon_height: 32,
      show_wordmark: true,
      link_url: path('niftybot_dashboard.main'),
    } %}
  </div>

  <div class="toggle-sidebar" id="toggle-sidebar" role="button" tabindex="0" aria-label="{{ 'Toggle sidebar'|t }}">
    <i class="bi bi-list"></i>
  </div>

  <div class="header-actions-container">
    <div class="header-actions d-flex align-items-center gap-3">
      {% if niftyoption_show_notifications %}
        <div class="niftybot-notifications dropdown"
             data-niftybot-notifications
             data-list-url="{{ path('niftybot_core.user_notifications_list') }}"
             data-unread-url="{{ path('niftybot_core.user_notifications_unread') }}"
             data-read-all-url="{{ path('niftybot_core.user_notifications_mark_all_read') }}">
          <button class="niftybot-notifications__toggle dropdown-toggle"
                  type="button"
                  id="niftybotNotificationsToggle"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                  aria-label="{{ 'Trade alerts'|t }}">
            <i class="bi bi-bell" aria-hidden="true"></i>
            <span class="niftybot-notifications__badge" data-niftybot-notifications-badge hidden>0</span>
          </button>
          <div class="dropdown-menu dropdown-menu-end niftybot-notifications__menu" aria-labelledby="niftybotNotificationsToggle">
            <div class="niftybot-notifications__head">
              <h6>{{ 'Trade alerts'|t }}</h6>
              <button type="button" class="niftybot-notifications__mark-all" data-niftybot-notifications-mark-all>
                {{ 'Mark all read'|t }}
              </button>
            </div>
            <ul class="niftybot-notifications__list" data-niftybot-notifications-list>
              <li class="niftybot-notifications__empty">{{ 'Loading…'|t }}</li>
            </ul>
          </div>
        </div>
      {% endif %}
      <a href="/niftybot/profile" class="niftybot-header-icon-link d-none d-xl-inline-flex" data-bs-toggle="tooltip" data-bs-placement="bottom" title="{{ 'Settings'|t }}">
        <i class="bi bi-gear fs-5" aria-hidden="true"></i>
      </a>
    </div>

    <div class="header-profile d-flex align-items-center">
      <div class="dropdown">
        <a href="#" id="userSettings" class="user-settings" data-bs-toggle="dropdown" aria-expanded="false">
          <span class="user-name d-none d-md-block">{{ niftyoption_user_name|default('Account'|t) }}</span>
          <span class="avatar">
            <img src="{{ assets_base }}/assets/images/user7.png" alt="{{ 'User avatar'|t }}" />
            <span class="status online"></span>
          </span>
        </a>
        <div class="dropdown-menu dropdown-menu-end" aria-labelledby="userSettings">
          <div class="header-profile-actions">
            <a href="/niftybot/profile">{{ 'Profile'|t }}</a>
            <a href="/niftybot/kyc">{{ 'KYC'|t }}</a>
            <a href="{{ path('user.logout') }}">{{ 'Logout'|t }}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
