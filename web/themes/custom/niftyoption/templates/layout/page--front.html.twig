{#
/**
 * @file
 * GrassRed public landing page — automated algo trading portal.
 */
#}
{% set brand_name = niftyoption_brand_name|default(site_name|default('GrassRed')) %}
<div class="landing-page">
  {% include directory ~ '/templates/includes/landing-header.html.twig' %}

  <main id="main-content" class="landing-page__main">
    <section class="landing-section landing-section--hero">
      <div class="container">
        <div class="landing-hero__banner">
          <div class="row align-items-center g-4">
            <div class="col-lg-7">
              <p class="landing-eyebrow landing-eyebrow--light">{{ 'Automated algo trading portal'|t }}</p>
              <h1 class="landing-hero__headline">
                {{ 'Algorithmic trading for Nifty &amp; Sensex — powered by @brand'|t({'@brand': brand_name}) }}
              </h1>
              <p class="landing-hero__subhead">
                {{ 'GrassRed is your all-in-one portal for AI-driven auto-trade, institutional signal stacks, wallet management, and transparent investment strategies on Indian index options.'|t }}
              </p>
              <div class="d-flex gap-2 flex-wrap landing-hero__actions">
                {% if logged_in %}
                  <a href="/niftybot/dashboard" class="btn btn-success btn-lg">{{ 'Go to Dashboard'|t }}</a>
                {% else %}
                  <a href="{{ path('niftybot_user.register') }}" class="btn btn-success btn-lg">{{ 'Start Free'|t }}</a>
                  <a href="{{ path('niftybot_core.public_features') }}" class="btn btn-outline-light btn-lg">{{ 'Explore Features'|t }}</a>
                {% endif %}
              </div>
              <div class="landing-hero__trust">
                <span class="landing-hero__trust-item"><i class="bi bi-gift" aria-hidden="true"></i> {{ '₹2,500 signup credit'|t }}</span>
                <span class="landing-hero__trust-item"><i class="bi bi-shield-check" aria-hidden="true"></i> {{ 'KYC verified'|t }}</span>
                <span class="landing-hero__trust-item"><i class="bi bi-robot" aria-hidden="true"></i> {{ 'AI algo engine'|t }}</span>
                <span class="landing-hero__trust-item"><i class="bi bi-graph-up" aria-hidden="true"></i> {{ 'Nifty & Sensex'|t }}</span>
              </div>
            </div>
            <div class="col-lg-5">
              <div class="landing-hero__panel">
                <div class="landing-hero__panel-header">
                  <span class="landing-hero__panel-dot"></span>
                  <span>{{ 'Live signal stack'|t }}</span>
                </div>
                <div class="landing-hero__panel-body">
                  {% for layer in [
                    {'name': 'Futures OI', 'status': 'Bullish buildup', 'pct': 87},
                    {'name': 'EMA Trend', 'status': 'Above 20 EMA', 'pct': 92},
                    {'name': 'RSI Momentum', 'status': 'Neutral-bullish', 'pct': 78},
                    {'name': 'VWAP + Chain OI', 'status': 'Confirmed', 'pct': 84},
                  ] %}
                    <div class="landing-hero__signal">
                      <div class="landing-hero__signal-label">
                        <strong>{{ layer.name }}</strong>
                        <span class="text-success">{{ layer.status }}</span>
                      </div>
                      <div class="progress landing-hero__progress" role="progressbar" aria-valuenow="{{ layer.pct }}" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar bg-success" style="width: {{ layer.pct }}%"></div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="landing-hero__cards row justify-content-center g-4">
          <div class="col-lg-4 col-md-6">
            <div class="card h-100 landing-card">
              <div class="card-body p-4 p-lg-5">
                <i class="bi bi-robot fs-1 text-primary mb-3 d-block" aria-hidden="true"></i>
                <h4 class="mb-2">{{ 'AI Algo Auto-Trade'|t }}</h4>
                <p class="text-secondary mb-0">{{ 'Multi-layer signal confirmation on Nifty & Sensex with automated entries, SL, and targets.'|t }}</p>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6">
            <div class="card h-100 landing-card">
              <div class="card-body p-4 p-lg-5">
                <i class="bi bi-graph-up-arrow fs-1 text-green mb-3 d-block" aria-hidden="true"></i>
                <h4 class="mb-2">{{ 'Managed Investment'|t }}</h4>
                <p class="text-secondary mb-0">{{ 'GrassRed AI investment plans with weekly profit payouts and published platform trades.'|t }}</p>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6">
            <div class="card h-100 landing-card">
              <div class="card-body p-4 p-lg-5">
                <i class="bi bi-shield-check fs-1 text-yellow mb-3 d-block" aria-hidden="true"></i>
                <h4 class="mb-2">{{ 'Secure Portal'|t }}</h4>
                <p class="text-secondary mb-0">{{ 'KYC verification, wallet management, Groww broker integration, and full audit trail.'|t }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section landing-section--welcome-bonus" id="welcome-bonus">
      <div class="container">
        <div class="landing-welcome-bonus">
          <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-7">
              <p class="landing-eyebrow">{{ 'New member offer'|t }}</p>
              <h2 class="landing-section__title mb-3">{{ 'Start with ₹2,500 trading credit — on us'|t }}</h2>
              <p class="landing-welcome-bonus__lead">
                {{ 'Create your free GrassRed account and we instantly add ₹2,500 to your wallet. Use it toward algo subscriptions, platform fees, or your first trades — no deposit required to get started.'|t }}
              </p>
              <ul class="landing-welcome-bonus__list">
                <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>{{ 'Credited automatically when you sign up'|t }}</span></li>
                <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>{{ 'Spend on subscriptions and algo trading'|t }}</span></li>
                <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>{{ 'Visible in your wallet balance from day one'|t }}</span></li>
              </ul>
              {% if not logged_in %}
                <a href="{{ path('niftybot_user.register') }}" class="btn btn-success btn-lg">{{ 'Claim ₹2,500 — Sign up free'|t }}</a>
              {% else %}
                <a href="/niftybot/wallet" class="btn btn-success btn-lg">{{ 'View your wallet'|t }}</a>
              {% endif %}
            </div>
            <div class="col-lg-5">
              <div class="landing-welcome-bonus__card" aria-hidden="true">
                <div class="landing-welcome-bonus__card-badge">{{ 'Welcome bonus'|t }}</div>
                <div class="landing-welcome-bonus__amount">₹2,500</div>
                <p class="landing-welcome-bonus__card-label">{{ 'Trading wallet credit'|t }}</p>
                <div class="landing-welcome-bonus__card-meta">
                  <span><i class="bi bi-lightning-charge" aria-hidden="true"></i> {{ 'Instant'|t }}</span>
                  <span><i class="bi bi-wallet2" aria-hidden="true"></i> {{ 'Wallet'|t }}</span>
                  <span><i class="bi bi-person-plus" aria-hidden="true"></i> {{ 'New users'|t }}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section landing-section--alt">
      <div class="container">
        <div class="text-center mb-2">
          <h2 class="landing-section__title">{{ 'How GrassRed works'|t }}</h2>
          <p class="landing-section__subtitle">{{ 'From signup to your first automated algo trade in three steps.'|t }}</p>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="landing-step">
              <div class="landing-step__icon"><i class="bi bi-person-plus" aria-hidden="true"></i></div>
              <h5>{{ '1. Create account'|t }}</h5>
              <p class="text-secondary mb-0">{{ 'Register at grassred.com and receive ₹2,500 trading credit in your wallet instantly. Complete KYC and connect your broker profile.'|t }}</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="landing-step">
              <div class="landing-step__icon"><i class="bi bi-wallet2" aria-hidden="true"></i></div>
              <h5>{{ '2. Fund & subscribe'|t }}</h5>
              <p class="text-secondary mb-0">{{ 'Deposit via UPI or NEFT and choose an algo trading subscription or investment plan.'|t }}</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="landing-step">
              <div class="landing-step__icon"><i class="bi bi-lightning-charge" aria-hidden="true"></i></div>
              <h5>{{ '3. Activate algo trading'|t }}</h5>
              <p class="text-secondary mb-0">{{ 'Turn on Nifty or Sensex auto-trade and let GrassRed AI execute disciplined entries.'|t }}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section">
      <div class="container">
        <div class="text-center mb-4">
          <h2 class="landing-section__title">{{ 'Built for active F&amp;O traders'|t }}</h2>
          <p class="landing-section__subtitle">{{ '@brand combines institutional-style algo signals with a trader-first dashboard.'|t({'@brand': brand_name}) }}</p>
        </div>
        <div class="row g-3 justify-content-center">
          <div class="col-sm-6 col-lg-3">
            <div class="landing-stat-box box-bdr-blue text-center">
              <h3 class="text-blue">75%+</h3>
              <p>{{ 'Min signal confidence'|t }}</p>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="landing-stat-box box-bdr-green text-center">
              <h3 class="text-green">2</h3>
              <p>{{ 'Indices — Nifty & Sensex'|t }}</p>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="landing-stat-box box-bdr-yellow text-center">
              <h3 class="text-yellow">6+</h3>
              <p>{{ 'Algo signal layers'|t }}</p>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="landing-stat-box box-bdr-red text-center">
              <h3 class="text-red">24/7</h3>
              <p>{{ 'Portfolio visibility'|t }}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section landing-section--alt" id="plans">
      <div class="container">
        <div class="text-center mb-4">
          <h2 class="landing-section__title">{{ 'Algo trading plans'|t }}</h2>
          <p class="landing-section__subtitle">{{ 'Flexible subscriptions for every trading style.'|t }}</p>
        </div>
        <div class="row justify-content-center g-4">
          <div class="col-lg-4 col-md-6">
            <div class="pricing-plan shade-primary">
              <div class="pricing-header">
                <h4 class="fw-lighter text-uppercase">{{ 'Starter'|t }}</h4>
                <h1>₹4,999</h1>
                <h5 class="fw-normal">{{ 'Per month'|t }}</h5>
              </div>
              <div class="pricing-body">
                <ul class="pricing-features">
                  <li>{{ 'Nifty & Sensex auto-trade'|t }}</li>
                  <li>{{ 'Live signal dashboard'|t }}</li>
                  <li>{{ '5 auto-trades per day'|t }}</li>
                </ul>
                <div class="pricing-footer">
                  <div class="d-grid">
                    <a href="{{ path('niftybot_core.public_pricing') }}" class="btn btn-light btn-lg">{{ 'View Plans'|t }}</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6">
            <div class="pricing-plan shade-green landing-pricing-plan--featured">
              <div class="landing-pricing-badge">{{ 'Most popular'|t }}</div>
              <div class="pricing-header">
                <h4 class="fw-lighter text-uppercase">{{ 'Pro'|t }}</h4>
                <h1>₹8,999</h1>
                <h5 class="fw-normal">{{ 'Per month'|t }}</h5>
              </div>
              <div class="pricing-body">
                <ul class="pricing-features">
                  <li>{{ '10 auto-trades per day'|t }}</li>
                  <li>{{ 'Custom trade quantity'|t }}</li>
                  <li>{{ 'Priority support'|t }}</li>
                </ul>
                <div class="pricing-footer">
                  <div class="d-grid">
                    <a href="{{ path('niftybot_core.public_pricing') }}" class="btn btn-light btn-lg">{{ 'View Plans'|t }}</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6">
            <div class="pricing-plan shade-blue">
              <div class="pricing-header">
                <h4 class="fw-lighter text-uppercase">{{ 'Elite'|t }}</h4>
                <h1>₹14,999</h1>
                <h5 class="fw-normal">{{ 'Per month'|t }}</h5>
              </div>
              <div class="pricing-body">
                <ul class="pricing-features">
                  <li>{{ '25 auto-trades per day'|t }}</li>
                  <li>{{ 'Highest capital limits'|t }}</li>
                  <li>{{ 'Dedicated support'|t }}</li>
                </ul>
                <div class="pricing-footer">
                  <div class="d-grid">
                    <a href="{{ path('niftybot_core.public_pricing') }}" class="btn btn-light btn-lg">{{ 'View Plans'|t }}</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section">
      <div class="container">
        <div class="row align-items-center g-5">
          <div class="col-lg-6">
            <h2 class="landing-section__title">{{ 'Why @brand?'|t({'@brand': brand_name}) }}</h2>
            <p class="text-secondary mb-4">
              {{ 'GrassRed was built for traders who want disciplined algo entries — not guesswork. Every auto-trade is backed by futures OI, trend, momentum, VWAP, volume, and option-chain confirmation.'|t }}
            </p>
            <ul class="landing-trust-list">
              <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>{{ 'Pullback & day-break entry timing'|t }}</span></li>
              <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>{{ 'Groww integration for live orders'|t }}</span></li>
              <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>{{ 'Full audit trail for every algo trade'|t }}</span></li>
              <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>{{ 'Wallet, KYC, and subscriptions in one portal'|t }}</span></li>
            </ul>
          </div>
          <div class="col-lg-6">
            <div class="landing-about-panel">
              <h3 class="mb-3">{{ 'Professional algo signal stack'|t }}</h3>
              <div class="landing-signal-grid">
                {% for signal in ['OI', 'EMA', 'RSI', 'VWAP', 'Volume', 'Chain OI'] %}
                  <div class="landing-signal-grid__item">
                    <strong>{{ signal }}</strong>
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section landing-section--alt pb-5">
      <div class="container">
        <div class="landing-cta">
          <h2>{{ 'Start algo trading with GrassRed'|t }}</h2>
          <p>{{ 'Join grassred.com today — create your account in minutes and explore the automated trading portal.'|t }}</p>
          <div class="d-flex gap-2 flex-wrap justify-content-center landing-cta__actions">
            <a href="{{ path('niftybot_user.register') }}" class="btn btn-success btn-lg">{{ 'Create Free Account'|t }}</a>
            <a href="{{ path('niftybot_core.public_faq') }}" class="btn btn-outline-light btn-lg">{{ 'Read FAQ'|t }}</a>
          </div>
        </div>
      </div>
    </section>

    {% if page.content %}
      <section class="landing-section">
        <div class="container">
          {{ page.content }}
        </div>
      </section>
    {% endif %}
  </main>

  {% include directory ~ '/templates/includes/landing-footer.html.twig' %}
</div>
