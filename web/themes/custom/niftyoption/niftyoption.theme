/**
 * Implements hook_preprocess_menu().
 */
function niftyoption_preprocess_menu(array &$variables): void {
  if (($variables['menu_name'] ?? '') !== 'dashboard-menu') {
    return;
  }
  $icon_map = _niftyoption_menu_icon_map();
  $variables['items'] = _niftyoption_menu_apply_icons($variables['items'], $icon_map);
  $variables['items'] = _niftyoption_menu_mark_active_items($variables['items']);
}

/**
 * Marks the menu item that matches the current route as active.
 *
 * Drupal menu items expose in_active_trail but not is_active in Twig; the custom
 * sidebar template needs is_active for highlighting the selected link.
 *
 * @param array<int, array<string, mixed>> $items
 *
 * @return array<int, array<string, mixed>>
 */
function _niftyoption_menu_mark_active_items(array $items): array {
  $route_match = \Drupal::routeMatch();
  $route_name = $route_match->getRouteName() ?? '';
  $route_params = $route_match->getRawParameters()->all();

  foreach ($items as $key => $item) {
    if (!empty($item['below'])) {
      $item['below'] = _niftyoption_menu_mark_active_items($item['below']);
      $child_active = _niftyoption_menu_has_active_item($item['below']);
      $item['is_active'] = !$child_active && _niftyoption_menu_link_is_active($item['url'], $route_name, $route_params);
      $item['expand_submenu'] = $child_active || !empty($item['in_active_trail']);
    }
    else {
      $item['is_active'] = _niftyoption_menu_link_is_active($item['url'], $route_name, $route_params);
    }
    $items[$key] = $item;
  }

  return $items;
}

/**
 * @param array<int, array<string, mixed>> $items
 */
function _niftyoption_menu_has_active_item(array $items): bool {
  foreach ($items as $item) {
    if (!empty($item['is_active'])) {
      return TRUE;
    }
    if (!empty($item['below']) && _niftyoption_menu_has_active_item($item['below'])) {
      return TRUE;
    }
  }
  return FALSE;
}

/**
 * @param \Drupal\Core\Url $url
 * @param array<string, mixed> $route_params
 */
function _niftyoption_menu_link_is_active(Url $url, string $route_name, array $route_params): bool {
  if ($route_name === '' || !$url->isRouted()) {
    return FALSE;
  }
  if ($url->getRouteName() !== $route_name) {
    return FALSE;
  }
  foreach ($url->getRouteParameters() as $key => $value) {
    if (!array_key_exists($key, $route_params) || (string) $route_params[$key] !== (string) $value) {
      return FALSE;
    }
  }
  return TRUE;
}

/**
 * @param array<int, array<string, mixed>> $items
 * @param array<string, string> $icon_map
 *
 * @return array<int, array<string, mixed>>
 */
function _niftyoption_menu_apply_icons(array $items, array $icon_map): array {
  foreach ($items as $key => $item) {
    $route = $item['url']->isRouted() ? $item['url']->getRouteName() : '';
    $options = $item['url']->getOptions();
    $option_classes = $options['attributes']['class'] ?? [];
    if (!is_array($option_classes)) {
      $option_classes = [$option_classes];
    }
    $custom_icon = NULL;
    foreach ($option_classes as $class) {
      if (is_string($class) && str_starts_with($class, 'menu-icon-')) {
        $custom_icon = substr($class, strlen('menu-icon-'));
        break;
      }
    }
    $items[$key]['icon'] = $custom_icon ?? ($icon_map[$route] ?? 'bi-circle');
    if (!empty($item['below'])) {
      $items[$key]['below'] = _niftyoption_menu_apply_icons($item['below'], $icon_map);
    }
  }
  return $items;
}

/**
 * Implements hook_preprocess_input().
 */
function niftyoption_preprocess_input(array &$variables): void {
  $route = \Drupal::routeMatch()->getRouteName();
  $auth_routes = _niftyoption_auth_routes();
  $variables['niftyoption_auth'] = in_array($route, $auth_routes, TRUE);
}

/**
 * Implements hook_form_alter().
 */
function niftyoption_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if ($form_id === 'user_login_form') {
    $form['#attributes']['class'][] = 'niftyoption-login-form';
    _niftyoption_style_auth_form($form);
    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary', 'w-100'];
      $form['actions']['submit']['#value'] = t('Login');
    }
  }
  if ($form_id === 'user_pass') {
    $form['#attributes']['class'][] = 'niftyoption-login-form';
    _niftyoption_style_password_request_form($form);
    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary', 'w-100'];
      $form['actions']['submit']['#value'] = t('Send reset link');
    }
  }
  if ($form_id === 'user_pass_reset') {
    $form['#attributes']['class'][] = 'niftyoption-login-form';
    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary', 'w-100'];
    }
    if (isset($form['message'])) {
      $form['message']['#prefix'] = '<div class="niftyoption-auth-message mb-3">';
      $form['message']['#suffix'] = '</div>';
    }
    if (isset($form['help'])) {
      $form['help']['#prefix'] = '<div class="niftyoption-auth-help text-secondary small mb-3">';
      $form['help']['#suffix'] = '</div>';
    }
  }
  if ($form_id === 'user_register_form') {
    $form['#attributes']['class'][] = 'niftyoption-login-form';
    _niftyoption_style_auth_form($form);
  }
  if ($form_id === 'niftybot_user_registration_form') {
    $form['#attributes']['class'][] = 'niftyoption-login-form';
    _niftyoption_registration_form_layout($form);
    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary', 'w-100'];
    }
  }
  if ($form_id === 'niftybot_wallet_deposit_form' || $form_id === 'niftybot_wallet_withdraw_form') {
    $form['#attributes']['class'][] = 'niftybot-wallet-form';
    _niftyoption_style_wallet_form($form);
    foreach (['submit', 'submit_neft'] as $submit_key) {
      if (isset($form['actions'][$submit_key])) {
        $form['actions'][$submit_key]['#attributes']['class'] = ['btn', 'btn-primary', 'btn-lg', 'niftybot-wallet-form__submit'];
      }
    }
  }
  if ($form_id === 'niftybot_kyc_submission_form') {
    _niftyoption_style_kyc_form($form);
  }
  if ($form_id === 'niftybot_order_form') {
    _niftyoption_style_order_form($form);
    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary', 'niftybot-order-form__submit'];
    }
  }
  if ($form_id === 'niftybot_broker_connection_form') {
    _niftyoption_style_broker_form($form);
    if (isset($form['layout']['credentials']['body']['actions']['submit'])) {
      $form['layout']['credentials']['body']['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary'];
    }
    if (isset($form['layout']['credentials']['body']['actions']['refresh'])) {
      $form['layout']['credentials']['body']['actions']['refresh']['#attributes']['class'] = ['btn', 'btn-outline-secondary'];
    }
  }
  if ($form_id === 'niftybot_subscribe_form') {
    _niftyoption_style_subscribe_form($form);
    if (isset($form['layout']['checkout']['body']['actions']['submit'])) {
      $form['layout']['checkout']['body']['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary'];
    }
  }

  $form['#after_build'][] = '_niftyoption_form_after_build_error_states';
}

/**
 * Applies dashboard form classes to wallet forms.
 */
function _niftyoption_style_wallet_form(array &$form): void {
  foreach (Element::children($form) as $key) {
    if (!isset($form[$key]) || !is_array($form[$key])) {
      continue;
    }
    $type = $form[$key]['#type'] ?? '';
    if (in_array($type, ['textfield', 'number', 'textarea', 'email', 'tel'], TRUE)) {
      $form[$key]['#attributes']['class'][] = 'form-control';
      $form[$key]['#wrapper_attributes']['class'][] = 'mb-3';
    }
    if ($type === 'radios') {
      $form[$key]['#attributes']['class'][] = 'niftybot-wallet-form__radios';
    }
    if (!in_array($type, ['submit', 'button', 'hidden', 'token', 'actions', 'markup'], TRUE)) {
      _niftyoption_style_wallet_form($form[$key]);
    }
  }
}

/**
 * Applies dashboard form classes to the subscribe form.
 */
function _niftyoption_style_subscribe_form(array &$form): void {
  foreach (Element::children($form) as $key) {
    if (!isset($form[$key]) || !is_array($form[$key])) {
      continue;
    }
    $type = $form[$key]['#type'] ?? '';
    if ($type === 'checkbox') {
      $form[$key]['#title_display'] = 'after';
    }
    if (!in_array($type, ['submit', 'button', 'hidden', 'token', 'actions', 'markup', 'link'], TRUE)) {
      _niftyoption_style_subscribe_form($form[$key]);
    }
  }
}

/**
 * Applies dashboard form classes to the broker connection form.
 */
function _niftyoption_style_broker_form(array &$form): void {
  $text_types = ['textfield', 'password', 'textarea'];
  foreach (Element::children($form) as $key) {
    if (!isset($form[$key]) || !is_array($form[$key])) {
      continue;
    }
    $type = $form[$key]['#type'] ?? '';
    if (in_array($type, $text_types, TRUE)) {
      $form[$key]['#attributes']['class'][] = 'form-control';
    }
    if (!in_array($type, ['submit', 'button', 'hidden', 'token', 'actions', 'markup'], TRUE)) {
      _niftyoption_style_broker_form($form[$key]);
    }
  }
}

/**
 * Applies dashboard form classes to the order placement form.
 */
function _niftyoption_style_order_form(array &$form): void {
  $text_types = ['textfield', 'number', 'textarea', 'email', 'tel'];
  foreach (Element::children($form) as $key) {
    if (!isset($form[$key]) || !is_array($form[$key])) {
      continue;
    }
    $type = $form[$key]['#type'] ?? '';
    if (in_array($type, $text_types, TRUE)) {
      $form[$key]['#attributes']['class'][] = 'form-control';
    }
    if ($type === 'select') {
      $form[$key]['#attributes']['class'][] = 'form-select';
    }
    if (!in_array($type, ['submit', 'button', 'hidden', 'token', 'actions', 'markup'], TRUE)) {
      _niftyoption_style_order_form($form[$key]);
    }
  }
}

/**
 * Applies Bloom-style classes to the KYC submission form.
 */
function _niftyoption_style_kyc_form(array &$form): void {
  $text_types = ['textfield', 'number', 'textarea', 'email', 'tel', 'date'];
  foreach (Element::children($form) as $key) {
    if (!isset($form[$key]) || !is_array($form[$key])) {
      continue;
    }
    $type = $form[$key]['#type'] ?? '';
    if (in_array($type, $text_types, TRUE)) {
      $form[$key]['#attributes']['class'][] = 'form-control';
    }
    if ($type === 'checkbox') {
      $form[$key]['#title_display'] = 'after';
    }
    if ($type === 'managed_file') {
      if (!isset($form[$key]['#wrapper_attributes']['class'])) {
        $form[$key]['#wrapper_attributes']['class'] = [];
      }
      if (!in_array('niftybot-kyc-form__file', $form[$key]['#wrapper_attributes']['class'], TRUE)) {
        $form[$key]['#wrapper_attributes']['class'][] = 'niftybot-kyc-form__file';
      }
    }
    if (!in_array($type, ['submit', 'button', 'hidden', 'token', 'actions', 'markup'], TRUE)) {
      _niftyoption_style_kyc_form($form[$key]);
    }
  }
}

/**
 * Adds Bootstrap invalid state classes after form errors are attached.
 */
function _niftyoption_form_after_build_error_states(array $form, FormStateInterface $form_state): array {
  _niftyoption_apply_form_field_error_states($form);
  return $form;
}

/**
 * Adds Bootstrap invalid state classes to fields with validation errors.
 */
function _niftyoption_apply_form_field_error_states(array &$element): void {
  $skip_types = ['submit', 'button', 'hidden', 'token', 'actions', 'markup', 'value'];
  $input_types = [
    'textfield', 'number', 'textarea', 'email', 'tel', 'date',
    'password', 'select', 'url', 'search', 'managed_file',
  ];

  foreach (Element::children($element) as $key) {
    if (!isset($element[$key]) || !is_array($element[$key])) {
      continue;
    }

    $type = $element[$key]['#type'] ?? '';
    if (!empty($element[$key]['#errors']) && in_array($type, $input_types, TRUE)) {
      $element[$key]['#attributes']['class'][] = 'is-invalid';
      $element[$key]['#attributes']['aria-invalid'] = 'true';
    }

    if (!in_array($type, $skip_types, TRUE)) {
      _niftyoption_apply_form_field_error_states($element[$key]);
    }
  }
}

/**
 * Two-column field layout for registration (desktop).
 */
function _niftyoption_registration_form_layout(array &$form): void {
  foreach (['full_name'] as $key) {
    if (!isset($form[$key]) || !is_array($form[$key])) {
      continue;
    }
    $form[$key]['#attributes']['class'][] = 'form-control';
    $form[$key]['#wrapper_attributes']['class'][] = 'mb-3';
  }

  foreach (['email', 'phone'] as $key) {
    if (!isset($form['contact_row'][$key]) || !is_array($form['contact_row'][$key])) {
      continue;
    }
    $form['contact_row'][$key]['#attributes']['class'][] = 'form-control';
    $form['contact_row'][$key]['#wrapper_attributes']['class'][] = 'mb-3';
  }

  if (isset($form['password_row']['password']['pass1'])) {
    $form['password_row']['password']['pass1']['#attributes']['class'][] = 'form-control';
    $form['password_row']['password']['pass1']['#wrapper_attributes']['class'][] = 'mb-3';
    $form['password_row']['password']['pass1']['#wrapper_attributes']['class'][] = 'col-md-6';
    $form['password_row']['password']['pass2']['#attributes']['class'][] = 'form-control';
    $form['password_row']['password']['pass2']['#wrapper_attributes']['class'][] = 'mb-3';
    $form['password_row']['password']['pass2']['#wrapper_attributes']['class'][] = 'col-md-6';
  }

  if (isset($form['terms'])) {
    $form['terms']['#wrapper_attributes']['class'][] = 'mb-3';
    $form['terms']['#title_display'] = 'after';
  }
}

/**
 * Apply theme form classes to the password request form.
 */
function _niftyoption_style_password_request_form(array &$form): void {
  if (isset($form['name']) && is_array($form['name']) && ($form['name']['#type'] ?? '') !== 'value') {
    $form['name']['#title'] = t('Your Email or username');
    $form['name']['#attributes']['class'][] = 'form-control';
    $form['name']['#attributes']['placeholder'] = t('Enter your email');
    $form['name']['#attributes']['inputmode'] = 'email';
    $form['name']['#wrapper_attributes']['class'][] = 'mb-3';
  }
  if (isset($form['mail'])) {
    $form['mail']['#prefix'] = '<div class="niftyoption-auth-help text-secondary small mb-3">';
    $form['mail']['#suffix'] = '</div>';
  }
}

/**
 * Apply theme form classes to login / register forms.
 */
function _niftyoption_style_auth_form(array &$form): void {
  if (isset($form['name'])) {
    $form['name']['#title'] = t('Your Email');
    $form['name']['#attributes']['class'][] = 'form-control';
    $form['name']['#attributes']['placeholder'] = t('Enter your email');
  }
  if (isset($form['pass'])) {
    $form['pass']['#title'] = t('Your Password');
    $form['pass']['#attributes']['class'][] = 'form-control';
    $form['pass']['#attributes']['placeholder'] = t('Enter password');
  }
  if (isset($form['mail'])) {
    $form['mail']['#attributes']['class'][] = 'form-control';
  }
  foreach (['name', 'mail', 'pass'] as $key) {
    if (!isset($form[$key]) || !is_array($form[$key])) {
      continue;
    }
    $form[$key]['#wrapper_attributes']['class'][] = 'mb-3';
  }
  if (isset($form['persistent_login'])) {
    $form['persistent_login']['#wrapper_attributes']['class'][] = 'form-check m-0';
    $form['persistent_login']['#title_display'] = 'after';
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for register submit label.
 */
function niftyoption_form_user_register_form_alter(array &$form, FormStateInterface $form_state): void {
  if (isset($form['actions']['submit'])) {
    $form['actions']['submit']['#attributes']['class'] = ['btn', 'btn-lg', 'btn-primary', 'w-100'];
    $form['actions']['submit']['#value'] = t('Create account');
  }
}

/**
 * Implements hook_theme_suggestions_page_alter().
 */
function niftyoption_theme_suggestions_page_alter(array &$suggestions, array $variables): void {
  $route = \Drupal::routeMatch()->getRouteName();
  if ($route === 'niftybot_core.landing' || $route === '<front>') {
    $suggestions[] = 'page__front';
  }
  elseif (in_array($route, [
    'niftybot_core.public_features',
    'niftybot_core.public_pricing',
    'niftybot_core.public_about',
    'niftybot_core.public_faq',
  ], TRUE)) {
    $suggestions[] = 'page__public';
  }

  if ($route === 'user.login') {
    $suggestions[] = 'page__user__login';
  }
  elseif ($route === 'user.register' || $route === 'niftybot_user.register') {
    $suggestions[] = 'page__user__register';
  }
  elseif (in_array($route, ['user.pass', 'user.reset', 'user.reset.form'], TRUE)) {
    $suggestions[] = 'page__user__password';
  }

  if (_niftyoption_anonymous_access_denied()) {
    $suggestions[] = 'page__access_denied';
  }
}

/**
 * Whether the current request should show the anonymous access-denied page.
 */
function _niftyoption_anonymous_access_denied(): bool {
  if (\Drupal::currentUser()->isAuthenticated()) {
    return FALSE;
  }

  $route = \Drupal::routeMatch()->getRouteName();
  if (_niftyoption_route_requires_login($route)) {
    return TRUE;
  }

  $path = \Drupal::service('path.current')->getPath();
  if (_niftyoption_path_requires_login($path)) {
    return TRUE;
  }

  $exception = \Drupal::request()->attributes->get('exception');
  return $exception instanceof AccessDeniedHttpException;
}

/**
 * Route names that require authentication for anonymous users.
 */
function _niftyoption_route_requires_login(?string $route): bool {
  if ($route === NULL || $route === '') {
    return FALSE;
  }

  $public_routes = [
    'user.login',
    'user.register',
    'user.pass',
    'niftybot_user.register',
    'niftybot_core.landing',
    'niftybot_core.public_features',
    'niftybot_core.public_pricing',
    'niftybot_core.public_about',
    'niftybot_core.public_faq',
    'niftybot_core.sitemap',
    '<front>',
    'system.404',
  ];
  if (in_array($route, $public_routes, TRUE)) {
    return FALSE;
  }

  if (str_starts_with($route, 'niftybot_')) {
    return TRUE;
  }

  return in_array($route, [
    'user_dashboard.dashboard',
    'user_dashboard.profile',
    'user_dashboard.node_edit',
    'user_dashboard.user_profile_edit',
  ], TRUE);
}

/**
 * Path prefixes that require authentication for anonymous users.
 */
function _niftyoption_path_requires_login(string $path): bool {
  $path = '/' . ltrim($path, '/');

  $public_paths = [
    '/niftybot/register',
    '/home',
    '/features',
    '/pricing',
    '/about',
    '/faq',
    '/sitemap.xml',
    '/user/login',
    '/user/register',
    '/user/password',
  ];
  foreach ($public_paths as $public) {
    if ($path === $public) {
      return FALSE;
    }
  }

  $protected_prefixes = [
    '/niftybot',
    '/admin/niftybot',
    '/admin/config/niftybot',
    '/user/dashboard',
    '/user/profile',
    '/user/my-profile',
    '/product-edit',
  ];
  foreach ($protected_prefixes as $prefix) {
    if ($path === $prefix || str_starts_with($path, $prefix . '/')) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Implements hook_preprocess_HOOK() for form elements.
 *
 * Surfaces inline validation errors (same behavior as inline_form_errors).
 */
function niftyoption_preprocess_form_element(array &$variables): void {
  $element = $variables['element'];
  if (!empty($element['#errors']) && empty($element['#error_no_message'])) {
    $variables['errors'] = $element['#errors'];
  }
}
