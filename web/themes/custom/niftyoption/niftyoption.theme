<?php

declare(strict_types=1);

/**
 * @file
 * Theme hooks for NiftyOption.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Element;
use Drupal\Core\Menu\MenuTreeParameters;
use Drupal\Core\Url;
use Symfony\Component\HttpKernel\Exception\AccessDeniedHttpException;

/**
 * Routes that use the standalone auth page shell (no dashboard chrome).
 *
 * @return string[]
 */
function _niftyoption_auth_routes(): array {
  return [
    'user.login',
    'user.register',
    'user.pass',
    'user.reset',
    'user.reset.form',
    'niftybot_user.register',
  ];
}

/**
 * Whether the current request is the public landing / front page.
 */
function _niftyoption_is_landing_page(?string $route = NULL): bool {
  return _niftyoption_is_public_marketing_page($route);
}

/**
 * Public marketing routes (landing layout, anonymous nav, SEO).
 *
 * @return string[]
 */
function _niftyoption_public_marketing_routes(): array {
  return [
    '<front>',
    'niftybot_core.landing',
    'niftybot_core.public_features',
    'niftybot_core.public_pricing',
    'niftybot_core.public_about',
    'niftybot_core.public_faq',
  ];
}

/**
 * Whether the current request uses the public marketing shell.
 */
function _niftyoption_is_public_marketing_page(?string $route = NULL): bool {
  $route ??= \Drupal::routeMatch()->getRouteName();
  if (in_array($route, _niftyoption_public_marketing_routes(), TRUE)) {
    return TRUE;
  }
  try {
    return \Drupal::service('path.matcher')->isFrontPage();
  }
  catch (\Exception) {
    return FALSE;
  }
}

/**
 * Anonymous-only top navigation links for public pages.
 *
 * @return array<int, array<string, mixed>>
 */
function _niftyoption_build_public_nav(?string $route = NULL): array {
  $route ??= \Drupal::routeMatch()->getRouteName();
  $links = [
    ['route' => 'niftybot_core.landing', 'title' => t('Home')],
    ['route' => 'niftybot_core.public_features', 'title' => t('Features')],
    ['route' => 'niftybot_core.public_pricing', 'title' => t('Pricing')],
    ['route' => 'niftybot_core.public_about', 'title' => t('About')],
    ['route' => 'niftybot_core.public_faq', 'title' => t('FAQ')],
  ];

  $items = [];
  foreach ($links as $link) {
    $route_name = $link['route'];
    $active = $route === $route_name || ($route === '<front>' && $route_name === 'niftybot_core.landing');
    $items[] = [
      'title' => $link['title'],
      'url' => Url::fromRoute($route_name)->toString(),
      'active' => $active,
    ];
  }
  return $items;
}

/**
 * SEO meta tags for public marketing pages.
 *
 * @return array<string, string>
 */
function _niftyoption_seo_meta(?string $route = NULL): array {
  $route ??= \Drupal::routeMatch()->getRouteName();
  $brand = [];
  _niftyoption_apply_brand_variables($brand);
  $site_name = $brand['niftyoption_brand_name'] ?? 'GrassRed';
  $base = 'https://grassred.com';

  $pages = [
    'niftybot_core.landing' => [
      'title' => 'GrassRed — Automated Algo Trading Portal | Nifty & Sensex',
      'description' => 'GrassRed is an automated algorithmic trading portal for Indian index options. AI-driven Nifty & Sensex auto-trade, investment plans, and full transparency at grassred.com.',
      'keywords' => 'GrassRed, grassred, grassred.com, algo trading, algorithmic trading, automated trading, nifty options, sensex trading, AI trading India',
    ],
    '<front>' => [
      'title' => 'GrassRed — Automated Algo Trading Portal | Nifty & Sensex',
      'description' => 'GrassRed is an automated algorithmic trading portal for Indian index options. AI-driven Nifty & Sensex auto-trade, investment plans, and full transparency at grassred.com.',
      'keywords' => 'GrassRed, grassred, grassred.com, algo trading, algorithmic trading, automated trading, nifty options, sensex trading, AI trading India',
    ],
    'niftybot_core.public_features' => [
      'title' => 'Algo Trading Features | GrassRed',
      'description' => 'Explore GrassRed algo trading features — AI engine, multi-layer signals, auto-trade execution, broker integration, and secure wallet on grassred.com.',
      'keywords' => 'GrassRed features, grassred features, algo trading features, automated nifty trading, AI trading signals',
    ],
    'niftybot_core.public_pricing' => [
      'title' => 'Pricing & Plans | GrassRed Algo Trading',
      'description' => 'GrassRed subscription plans for automated algo trading. Starter, Pro, and Elite tiers plus AI investment options at grassred.com.',
      'keywords' => 'GrassRed pricing, grassred pricing, algo trading plans, nifty auto trade subscription',
    ],
    'niftybot_core.public_about' => [
      'title' => 'About GrassRed — Automated Algo Trading Portal',
      'description' => 'Learn about GrassRed — an automated algorithmic trading portal built for Indian F&O traders. Mission, technology, and transparency at grassred.com.',
      'keywords' => 'about GrassRed, about grassred, grassred company, algorithmic trading portal India',
    ],
    'niftybot_core.public_faq' => [
      'title' => 'FAQ | GrassRed Algo Trading Portal',
      'description' => 'Frequently asked questions about GrassRed automated algo trading, subscriptions, KYC, wallet, and AI investment at grassred.com.',
      'keywords' => 'GrassRed FAQ, grassred FAQ, algo trading help, GrassRed support',
    ],
  ];

  $meta = $pages[$route] ?? [
    'title' => $site_name,
    'description' => 'GrassRed — automated algorithmic trading portal at grassred.com',
    'keywords' => 'GrassRed, grassred, algo trading, grassred.com',
  ];

  $path = match ($route) {
    'niftybot_core.public_features' => '/features',
    'niftybot_core.public_pricing' => '/pricing',
    'niftybot_core.public_about' => '/about',
    'niftybot_core.public_faq' => '/faq',
    default => '/home',
  };

  $meta['canonical'] = $base . $path;
  $meta['og_image'] = ($brand['theme_assets_base'] ?? '') . '/assets/images/logo.png';
  return $meta;
}

/**
 * Attaches SEO meta tags to the page head.
 */
function _niftyoption_attach_seo(array &$attachments, ?string $route = NULL): void {
  $meta = _niftyoption_seo_meta($route);
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'meta', '#attributes' => ['name' => 'description', 'content' => $meta['description']]],
    'grassred_description',
  ];
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'meta', '#attributes' => ['name' => 'keywords', 'content' => $meta['keywords']]],
    'grassred_keywords',
  ];
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'link', '#attributes' => ['rel' => 'canonical', 'href' => $meta['canonical']]],
    'grassred_canonical',
  ];
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'meta', '#attributes' => ['property' => 'og:title', 'content' => $meta['title']]],
    'grassred_og_title',
  ];
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'meta', '#attributes' => ['property' => 'og:description', 'content' => $meta['description']]],
    'grassred_og_description',
  ];
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'meta', '#attributes' => ['property' => 'og:url', 'content' => $meta['canonical']]],
    'grassred_og_url',
  ];
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'meta', '#attributes' => ['property' => 'og:site_name', 'content' => 'GrassRed']],
    'grassred_og_site',
  ];
  $attachments['#attached']['html_head'][] = [
    ['#tag' => 'meta', '#attributes' => ['property' => 'og:type', 'content' => 'website']],
    'grassred_og_type',
  ];
  $attachments['#attached']['html_head'][] = [
    [
      '#tag' => 'script',
      '#attributes' => ['type' => 'application/ld+json'],
      '#value' => json_encode([
        '@context' => 'https://schema.org',
        '@type' => 'WebSite',
        'name' => 'GrassRed',
        'url' => 'https://grassred.com',
        'description' => $meta['description'],
        'potentialAction' => [
          '@type' => 'SearchAction',
          'target' => 'https://grassred.com/faq?q={search_term_string}',
          'query-input' => 'required name=search_term_string',
        ],
      ], JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE),
    ],
    'grassred_jsonld',
  ];
}

/**
 * Sets theme asset base path and portal brand name on template variables.
 */
function _niftyoption_apply_brand_variables(array &$variables): void {
  if (empty($variables['theme_assets_base'])) {
    $theme_path = \Drupal::theme()->getActiveTheme()->getPath();
    $variables['theme_assets_base'] = base_path() . ltrim($theme_path, '/');
  }

  if (empty($variables['site_name'])) {
    $variables['site_name'] = (string) \Drupal::config('system.site')->get('name');
  }

  $site_name = $variables['site_name'];
  if ($site_name === '' || $site_name === 'Drush Site-Install') {
    $variables['niftyoption_brand_name'] = 'GrassRed';
  }
  else {
    $variables['niftyoption_brand_name'] = $site_name;
  }

  $asset_version = _niftyoption_asset_version();
  $variables['niftyoption_logo_version'] = $asset_version;
  $base = $variables['theme_assets_base'];
  $variables['niftyoption_logo_url'] = $base . '/assets/images/logo.png?v=' . $asset_version;
  $variables['niftyoption_logo_icon_url'] = $variables['niftyoption_logo_url'];
  $variables['niftyoption_favicon_url'] = $base . '/favicon.ico?v=' . $asset_version;
  $variables['niftyoption_favicon_svg_url'] = $base . '/assets/images/favicon-32x32.png?v=' . $asset_version;
  $variables['niftyoption_favicon_ico_url'] = $base . '/favicon.ico?v=' . $asset_version;
  $variables['niftyoption_favicon_png_32_url'] = $base . '/assets/images/favicon-32x32.png?v=' . $asset_version;
  $variables['niftyoption_apple_touch_icon_url'] = $base . '/assets/images/apple-touch-icon.png?v=' . $asset_version;
}

/**
 * Cache-busting token for static brand assets (SVG/ICO/PNG are heavily cached).
 */
function _niftyoption_asset_version(): string {
  static $version = NULL;
  if ($version !== NULL) {
    return $version;
  }

  $theme_path = \Drupal::theme()->getActiveTheme()->getPath();
  $candidates = [
    $theme_path . '/assets/images/logo.png',
    $theme_path . '/favicon.ico',
    $theme_path . '/assets/images/favicon-32x32.png',
  ];

  $mtime = 0;
  foreach ($candidates as $relative) {
    $full = DRUPAL_ROOT . '/' . $relative;
    if (is_file($full)) {
      $mtime = max($mtime, (int) filemtime($full));
    }
  }

  $version = $mtime > 0 ? (string) $mtime : '1';
  return $version;
}

/**
 * @deprecated Use _niftyoption_asset_version().
 */
function _niftyoption_logo_version(): string {
  return _niftyoption_asset_version();
}

/**
 * Attaches GrassRed favicon link tags and removes the default Drupal icon.
 */
function _niftyoption_attach_favicon(array &$variables): void {
  if (!empty($variables['#attached']['html_head_link'])) {
    $variables['#attached']['html_head_link'] = array_values(array_filter(
      $variables['#attached']['html_head_link'],
      static function (array $link): bool {
        $rel = $link[0]['rel'] ?? '';
        return !in_array($rel, ['icon', 'shortcut icon'], TRUE);
      }
    ));
  }

  $variables['#attached']['html_head_link'][] = [
    [
      'rel' => 'icon',
      'href' => $variables['niftyoption_favicon_ico_url'],
      'sizes' => 'any',
    ],
  ];
  $variables['#attached']['html_head_link'][] = [
    [
      'rel' => 'apple-touch-icon',
      'href' => $variables['niftyoption_apple_touch_icon_url'],
    ],
  ];
}

/**
 * Implements hook_preprocess_html().
 */
function niftyoption_preprocess_html(array &$variables): void {
  $route = \Drupal::routeMatch()->getRouteName();
  $login_routes = _niftyoption_auth_routes();
  $is_landing = _niftyoption_is_landing_page($route);

  _niftyoption_apply_brand_variables($variables);

  if (in_array($route, $login_routes, TRUE) || _niftyoption_anonymous_access_denied()) {
    $variables['attributes']['class'][] = 'login-container';
    $variables['#attached']['library'][] = 'niftyoption/login';
    $variables['niftyoption_layout'] = 'login';
  }
  elseif ($is_landing) {
    $variables['#attached']['library'][] = 'niftyoption/landing';
    $variables['niftyoption_layout'] = 'landing';
  }
  else {
    $variables['#attached']['library'][] = 'niftyoption/dashboard';
    $variables['niftyoption_layout'] = 'dashboard';
  }
}

/**
 * Implements hook_page_attachments_alter().
 */
function niftyoption_page_attachments_alter(array &$attachments): void {
  if (\Drupal::theme()->getActiveTheme()->getName() !== 'niftyoption') {
    return;
  }

  if (!empty($attachments['#attached']['html_head_link'])) {
    $attachments['#attached']['html_head_link'] = array_values(array_filter(
      $attachments['#attached']['html_head_link'],
      static function (array $link): bool {
        $rel = $link[0]['rel'] ?? '';
        return !in_array($rel, ['icon', 'shortcut icon', 'apple-touch-icon'], TRUE);
      }
    ));
  }

  $brand = [];
  _niftyoption_apply_brand_variables($brand);
  _niftyoption_attach_favicon($brand);

  $attachments['#attached']['html_head_link'] = array_merge(
    $attachments['#attached']['html_head_link'] ?? [],
    $brand['#attached']['html_head_link'] ?? []
  );

  $route = \Drupal::routeMatch()->getRouteName();
  if (_niftyoption_is_public_marketing_page($route)) {
    _niftyoption_attach_seo($attachments, $route);
  }
}

/**
 * Implements hook_preprocess_page().
 */
function niftyoption_preprocess_page(array &$variables): void {
  $account = \Drupal::currentUser();
  if ($account->isAuthenticated()) {
    $user = \Drupal::entityTypeManager()->getStorage('user')->load($account->id());
    $variables['niftyoption_user_name'] = $user ? niftybot_user_display_name($user) : $account->getDisplayName();
    $variables['niftyoption_user_avatar_url'] = niftybot_user_avatar_url($user);
  }
  else {
    $variables['niftyoption_user_name'] = '';
    $variables['niftyoption_user_avatar_url'] = niftybot_user_avatar_url();
  }

  _niftyoption_apply_brand_variables($variables);

  $route = \Drupal::routeMatch()->getRouteName();
  $login_routes = _niftyoption_auth_routes();
  $is_landing = _niftyoption_is_landing_page($route);

  $access_denied = _niftyoption_anonymous_access_denied();
  $variables['niftyoption_access_denied'] = $access_denied;
  $variables['niftyoption_show_notifications'] = FALSE;

  if (
    $account->isAuthenticated()
    && !$access_denied
    && !$is_landing
    && !in_array($route, $login_routes, TRUE)
    && $account->hasPermission('access niftybot platform')
  ) {
    $variables['niftyoption_show_notifications'] = TRUE;
    $variables['#attached']['library'][] = 'niftybot_core/notifications';
    $variables['#attached']['drupalSettings']['niftybotNotifications'] = [
      'csrfToken' => \Drupal::csrfToken()->get('niftybot_notifications'),
      'readUrlTemplate' => Url::fromRoute('niftybot_core.user_notifications_mark_read', ['alert_id' => 0])->toString(),
    ];
  }

  if ($route === 'niftybot_dashboard.main') {
    $variables['title'] = '';
  }

  if ($route === 'niftybot_user.profile') {
    $variables['title'] = '';
  }

  if ($route === 'niftybot_trading.order_form') {
    $variables['title'] = '';
  }

  $hide_title_routes = [
    'niftybot_core.user_broker',
    'niftybot_core.user_auto_trade',
    'niftybot_core.user_auto_trade_nifty',
    'niftybot_core.user_auto_trade_sensex',
    'niftybot_core.user_auto_trade_crude_oil',
    'niftybot_core.user_auto_trade_gold',
    'niftybot_subscription.subscribe',
  ];
  if (in_array($route, $hide_title_routes, TRUE)) {
    $variables['title'] = '';
  }

  if ($access_denied) {
    $variables['niftyoption_dashboard_menu'] = [];
    $variables['niftyoption_login_url'] = Url::fromRoute('user.login', [], [
      'query' => ['destination' => \Drupal::service('path.current')->getPath()],
    ])->toString();
  }
  elseif (!$is_landing && !in_array($route, $login_routes, TRUE)) {
    $variables['niftyoption_dashboard_menu'] = _niftyoption_build_dashboard_menu();
  }
  else {
    $variables['niftyoption_dashboard_menu'] = [];
  }

  $variables['niftyoption_public_nav'] = [];
  if (!$account->isAuthenticated() && $is_landing) {
    $variables['niftyoption_public_nav'] = _niftyoption_build_public_nav($route);
  }

  $public_marketing_routes = [
    'niftybot_core.public_features',
    'niftybot_core.public_pricing',
    'niftybot_core.public_about',
    'niftybot_core.public_faq',
  ];
  if (in_array($route, $public_marketing_routes, TRUE)) {
    $variables['title'] = '';
  }
}

/**
 * Implements hook_preprocess_menu_local_tasks().
 */
function niftyoption_preprocess_menu_local_tasks(array &$variables): void {
  $route = \Drupal::routeMatch()->getRouteName();
  if (!in_array($route, _niftyoption_auth_routes(), TRUE)) {
    return;
  }

  $variables['niftyoption_auth_tabs'] = TRUE;

  if (!empty($variables['primary'])) {
    foreach (Element::children($variables['primary']) as $key) {
      if (($variables['primary'][$key]['#link']['url']->getRouteName() ?? '') === 'user.register') {
        $variables['primary'][$key]['#link']['url'] = Url::fromRoute('niftybot_user.register');
        $variables['primary'][$key]['#link']['title'] = t('Create new account');
      }
    }
  }
}

/**
 * Implements hook_preprocess_menu_local_task().
 */
function niftyoption_preprocess_menu_local_task(array &$variables): void {
  $route = \Drupal::routeMatch()->getRouteName();
  if (!in_array($route, _niftyoption_auth_routes(), TRUE)) {
    return;
  }

  $variables['attributes']['class'][] = 'niftyoption-auth-tabs__item';
  $variables['link']['#options']['attributes']['class'][] = 'btn';
  $variables['link']['#options']['attributes']['class'][] = 'btn-sm';
  $variables['link']['#options']['attributes']['class'][] = !empty($variables['is_active'])
    ? 'btn-primary'
    : 'btn-outline-primary';
}

/**
 * Builds the dashboard sidebar menu render array.
 */
function _niftyoption_build_dashboard_menu(): array {
  $menu_tree = \Drupal::menuTree();
  $parameters = new MenuTreeParameters();
  $parameters->onlyEnabledLinks();
  $tree = $menu_tree->load('dashboard-menu', $parameters);
  $manipulators = [
    ['callable' => 'menu.default_tree_manipulators:checkAccess'],
    ['callable' => 'menu.default_tree_manipulators:generateIndexAndSort'],
  ];
  $tree = $menu_tree->transform($tree, $manipulators);
  return $menu_tree->build($tree);
}

