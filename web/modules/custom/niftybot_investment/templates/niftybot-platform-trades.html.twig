<div class="niftybot-investment niftybot-platform-trades">
  <p class="investment-intro">
    {{ 'Daily Nifty trades executed by the FXC Global AI model. Profit and loss is shown per trade and per day.'|t }}
  </p>

  {% if daily_summary is empty %}
    <p class="empty-state">{{ 'No platform trades recorded yet.'|t }}</p>
  {% else %}
    <div class="daily-pnl-summary">
      <h3>{{ 'Daily P&L summary'|t }}</h3>
      <table class="niftybot-table compact">
        <thead>
          <tr>
            <th>{{ 'Date'|t }}</th>
            <th>{{ 'Trades'|t }}</th>
            <th>{{ 'Day P&L'|t }}</th>
          </tr>
        </thead>
        <tbody>
          {% for date, summary in daily_summary %}
            <tr>
              <td>{{ summary.label }}</td>
              <td>{{ summary.count }}</td>
              <td class="{{ summary.pnl_class }}">
                {{ summary.pnl >= 0 ? '+' : '' }}₹{{ summary.pnl|number_format(2) }}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% for date, trades in grouped_trades %}
      <div class="trade-day-group">
        <h3 class="trade-day-heading">
          {{ day_meta[date].label }}
          <span class="day-pnl {{ day_meta[date].pnl_class }}">
            {{ day_meta[date].pnl >= 0 ? '+' : '' }}₹{{ day_meta[date].pnl_formatted }}
          </span>
        </h3>
        <table class="niftybot-table">
          <thead>
            <tr>
              <th>{{ 'Symbol'|t }}</th>
              <th>{{ 'Strategy'|t }}</th>
              <th>{{ 'Type'|t }}</th>
              <th>{{ 'Qty'|t }}</th>
              <th>{{ 'Entry'|t }}</th>
              <th>{{ 'Exit'|t }}</th>
              <th>{{ 'P&L'|t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for trade in trades %}
              <tr>
                <td>{{ trade.symbol }}</td>
                <td>{{ trade.strategy }}</td>
                <td>
                  <span class="txn-type txn-type--{{ trade.transaction_type|lower }}">{{ trade.transaction_type }}</span>
                </td>
                <td>{{ trade.quantity }}</td>
                <td>₹{{ trade.entry_price|number_format(2) }}</td>
                <td>₹{{ trade.exit_price|number_format(2) }}</td>
                <td class="{{ trade.pnl_class }}">
                  {{ trade.pnl >= 0 ? '+' : '' }}₹{{ trade.pnl_formatted }}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endfor %}
  {% endif %}

  <p><a href="{{ path('niftybot_investment.dashboard') }}" class="button">{{ 'Back to FXC Investment'|t }}</a></p>
</div>
