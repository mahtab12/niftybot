{#
/**
 * @file
 * StrikeFlow platform Nifty trades — investor transparency.
 */
#}
<div class="niftybot-trading-page niftybot-platform-trades niftybot-dashboard">
  <div class="niftybot-trading-page__hero card mb-4 niftybot-platform-trades__hero">
    <div class="niftybot-trading-page__hero-bg" aria-hidden="true"></div>
    <div class="card-body position-relative">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <div class="d-flex align-items-start gap-3">
            <div class="niftybot-trading-page__hero-icon" aria-hidden="true">
              <i class="bi bi-robot"></i>
            </div>
            <div>
              <p class="niftybot-trading-page__hero-label mb-2">{{ 'StrikeFlow Investment — algo P&L'|t }}</p>
              <h2 class="niftybot-trading-page__hero-amount mb-0 {{ summary.total_pnl|default(0) >= 0 ? 'niftybot-trading-page__hero-amount--positive' : 'niftybot-trading-page__hero-amount--negative' }}">
                {{ summary.total_pnl|default(0) >= 0 ? '+' : '' }}₹{{ summary.total_pnl|default(0)|number_format(2) }}
              </h2>
              <p class="niftybot-trading-page__hero-hint mb-0">
                {{ 'Daily Nifty trades executed by StrikeFlow AI and algorithmic models. P&L is shown per trade and per session.'|t }}
              </p>
            </div>
          </div>

          <div class="niftybot-trading-page__hero-meta">
            <div class="niftybot-trading-page__hero-stat">
              <span class="niftybot-trading-page__hero-stat-label">{{ 'Total trades'|t }}</span>
              <span class="niftybot-trading-page__hero-stat-value">{{ summary.total_trades|default(0) }}</span>
            </div>
            <div class="niftybot-trading-page__hero-stat">
              <span class="niftybot-trading-page__hero-stat-label">{{ 'Trading days'|t }}</span>
              <span class="niftybot-trading-page__hero-stat-value">{{ summary.trading_days|default(0) }}</span>
            </div>
            <div class="niftybot-trading-page__hero-stat">
              <span class="niftybot-trading-page__hero-stat-label">{{ 'Winning days'|t }}</span>
              <span class="niftybot-trading-page__hero-stat-value">{{ summary.winning_days|default(0) }}</span>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="niftybot-trading-page__hero-actions">
            <a href="{{ path('niftybot_investment.dashboard') }}" class="btn btn-light">
              <i class="bi bi-pie-chart me-2" aria-hidden="true"></i>
              {{ 'Investment dashboard'|t }}
            </a>
            <a href="{{ path('niftybot_investment.plans') }}" class="btn btn-outline-light">
              <i class="bi bi-tags me-2" aria-hidden="true"></i>
              {{ 'Plans'|t }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if daily_summary is empty %}
    <div class="card niftybot-trading-page__table-card">
      <div class="card-body">
        <div class="niftybot-trading-page__empty">
          <i class="bi bi-graph-down niftybot-trading-page__empty-icon" aria-hidden="true"></i>
          <h3 class="niftybot-trading-page__empty-title">{{ 'No platform trades yet'|t }}</h3>
          <p class="niftybot-trading-page__empty-text">
            {{ 'Recorded Nifty trades from StrikeFlow algo strategies will appear here for full transparency.'|t }}
          </p>
          <div class="niftybot-trading-page__empty-actions">
            <a href="{{ path('niftybot_investment.dashboard') }}" class="btn btn-primary">
              {{ 'Back to investment'|t }}
            </a>
          </div>
        </div>
      </div>
    </div>
  {% else %}
    <div class="row g-3 mb-4">
      <div class="col-sm-6 col-lg-3">
        <div class="niftybot-trading-page__stat-card">
          <div class="niftybot-trading-page__stat-card-top">
            <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--trades" aria-hidden="true">
              <i class="bi bi-receipt"></i>
            </div>
          </div>
          <div class="niftybot-trading-page__stat-value">{{ summary.total_trades|default(0) }}</div>
          <div class="niftybot-trading-page__stat-label">{{ 'Platform trades'|t }}</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="niftybot-trading-page__stat-card">
          <div class="niftybot-trading-page__stat-card-top">
            <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--positions" aria-hidden="true">
              <i class="bi bi-calendar3"></i>
            </div>
          </div>
          <div class="niftybot-trading-page__stat-value">{{ summary.trading_days|default(0) }}</div>
          <div class="niftybot-trading-page__stat-label">{{ 'Trading days'|t }}</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="niftybot-trading-page__stat-card">
          <div class="niftybot-trading-page__stat-card-top">
            <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--executed" aria-hidden="true">
              <i class="bi bi-trophy"></i>
            </div>
          </div>
          <div class="niftybot-trading-page__stat-value">{{ summary.winning_days|default(0) }}</div>
          <div class="niftybot-trading-page__stat-label">{{ 'Winning days'|t }}</div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="niftybot-trading-page__stat-card">
          <div class="niftybot-trading-page__stat-card-top">
            <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--investment" aria-hidden="true">
              <i class="bi bi-graph-up-arrow"></i>
            </div>
          </div>
          <div class="niftybot-trading-page__stat-value {{ summary.total_pnl|default(0) >= 0 ? 'niftybot-trading-page__pnl--positive' : 'niftybot-trading-page__pnl--negative' }}">
            {{ summary.total_pnl|default(0) >= 0 ? '+' : '' }}₹{{ summary.total_pnl|default(0)|number_format(0) }}
          </div>
          <div class="niftybot-trading-page__stat-label">{{ 'Cumulative P&L'|t }}</div>
        </div>
      </div>
    </div>

    <div class="card niftybot-trading-page__table-card mb-4">
      <div class="card-header">
        <h3 class="niftybot-trading-page__table-title">
          <i class="bi bi-bar-chart-line" aria-hidden="true"></i>
          {{ 'Daily P&L summary'|t }}
        </h3>
        <p class="niftybot-trading-page__table-subtitle mb-0">
          {{ 'Last @count trading sessions'|t({'@count': daily_summary|length}) }}
        </p>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover nowrap mb-0 niftybot-table compact">
            <thead>
              <tr>
                <th scope="col">{{ 'Date'|t }}</th>
                <th scope="col">{{ 'Trades'|t }}</th>
                <th scope="col">{{ 'Day P&L'|t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for date, day in daily_summary %}
                <tr>
                  <td data-label="{{ 'Date'|t }}">{{ day.label }}</td>
                  <td data-label="{{ 'Trades'|t }}">{{ day.count }}</td>
                  <td data-label="{{ 'Day P&L'|t }}" class="{{ day.pnl >= 0 ? 'niftybot-trading-page__pnl--positive' : 'niftybot-trading-page__pnl--negative' }} fw-semibold">
                    {{ day.pnl >= 0 ? '+' : '' }}₹{{ day.pnl|number_format(2) }}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <h3 class="niftybot-platform-trades__section-heading">
      <i class="bi bi-journal-text" aria-hidden="true"></i>
      {{ 'Trade log by day'|t }}
    </h3>

    {% for date, trades in grouped_trades %}
      <div class="card niftybot-trading-page__table-card niftybot-platform-trades__day-card mb-3">
        <div class="card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
          <h4 class="niftybot-platform-trades__day-title mb-0">{{ day_meta[date].label }}</h4>
          <span class="niftybot-platform-trades__day-pnl {{ day_meta[date].pnl >= 0 ? 'niftybot-trading-page__pnl--positive' : 'niftybot-trading-page__pnl--negative' }}">
            {{ day_meta[date].pnl >= 0 ? '+' : '' }}₹{{ day_meta[date].pnl_formatted }}
          </span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-striped table-hover nowrap mb-0 niftybot-table">
              <thead>
                <tr>
                  <th scope="col">{{ 'Symbol'|t }}</th>
                  <th scope="col">{{ 'Strategy'|t }}</th>
                  <th scope="col">{{ 'Type'|t }}</th>
                  <th scope="col">{{ 'Qty'|t }}</th>
                  <th scope="col">{{ 'Entry'|t }}</th>
                  <th scope="col">{{ 'Exit'|t }}</th>
                  <th scope="col">{{ 'P&L'|t }}</th>
                </tr>
              </thead>
              <tbody>
                {% for trade in trades %}
                  <tr>
                    <td data-label="{{ 'Symbol'|t }}" class="niftybot-trading-page__symbol">{{ trade.symbol }}</td>
                    <td data-label="{{ 'Strategy'|t }}" class="niftybot-trading-page__strategy">{{ trade.strategy }}</td>
                    <td data-label="{{ 'Type'|t }}">
                      <span class="niftybot-trading-page__txn-badge niftybot-trading-page__txn-badge--{{ trade.transaction_type|lower }}">
                        {{ trade.transaction_type }}
                      </span>
                    </td>
                    <td data-label="{{ 'Qty'|t }}">{{ trade.quantity }}</td>
                    <td data-label="{{ 'Entry'|t }}">₹{{ trade.entry_price|number_format(2) }}</td>
                    <td data-label="{{ 'Exit'|t }}">₹{{ trade.exit_price|number_format(2) }}</td>
                    <td data-label="{{ 'P&L'|t }}" class="{{ trade.pnl >= 0 ? 'niftybot-trading-page__pnl--positive' : 'niftybot-trading-page__pnl--negative' }} fw-semibold">
                      {{ trade.pnl >= 0 ? '+' : '' }}₹{{ trade.pnl_formatted }}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    {% endfor %}
  {% endif %}
</div>
