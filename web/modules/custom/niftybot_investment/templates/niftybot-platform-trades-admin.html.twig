<div class="niftybot-investment">
  <div class="admin-actions">{{ add_link }}</div>

  {% if trades is empty %}
    <p>{{ 'No trades yet. Add the first platform trade.'|t }}</p>
  {% else %}
    <table class="niftybot-table">
      <thead>
        <tr>
          <th>{{ 'Date'|t }}</th>
          <th>{{ 'Symbol'|t }}</th>
          <th>{{ 'Type'|t }}</th>
          <th>{{ 'Entry'|t }}</th>
          <th>{{ 'Exit'|t }}</th>
          <th>{{ 'P&L'|t }}</th>
          <th>{{ 'Actions'|t }}</th>
        </tr>
      </thead>
      <tbody>
        {% for trade in trades %}
          <tr>
            <td>{{ trade.trade_date }}</td>
            <td>{{ trade.symbol }}</td>
            <td>{{ trade.transaction_type }}</td>
            <td>₹{{ trade.entry_price|number_format(2) }}</td>
            <td>₹{{ trade.exit_price|number_format(2) }}</td>
            <td class="{{ trade.pnl >= 0 ? 'pnl-positive' : 'pnl-negative' }}">
              {{ trade.pnl >= 0 ? '+' : '' }}₹{{ trade.pnl|number_format(2) }}
            </td>
            <td>
              <a href="{{ path('niftybot_investment.admin_trade_edit', {'trade_id': trade.trade_id}) }}">{{ 'Edit'|t }}</a>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>
