{#
/**
 * @file
 * Executed trade history.
 */
#}
<div class="niftybot-trading-page niftybot-dashboard">
  <div class="niftybot-trading-page__hero card mb-4">
    <div class="niftybot-trading-page__hero-bg" aria-hidden="true"></div>
    <div class="card-body position-relative">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <div class="d-flex align-items-start gap-3">
            <div class="niftybot-trading-page__hero-icon" aria-hidden="true">
              <i class="bi bi-clock-history"></i>
            </div>
            <div>
              <p class="niftybot-trading-page__hero-label mb-2">{{ 'Net P&L (executed)'|t }}</p>
              <h2 class="niftybot-trading-page__hero-amount mb-0 {{ summary.net_pnl >= 0 ? 'niftybot-trading-page__hero-amount--positive' : 'niftybot-trading-page__hero-amount--negative' }}">
                {{ summary.net_pnl >= 0 ? '+' : '' }}₹{{ summary.net_pnl|number_format(2) }}
              </h2>
              <p class="niftybot-trading-page__hero-hint mb-0">
                {{ 'Completed and partially filled orders from your account'|t }}
              </p>
            </div>
          </div>

          <div class="niftybot-trading-page__hero-meta">
            <div class="niftybot-trading-page__hero-stat">
              <span class="niftybot-trading-page__hero-stat-label">{{ 'Total trades'|t }}</span>
              <span class="niftybot-trading-page__hero-stat-value">{{ summary.total_trades }}</span>
            </div>
            <div class="niftybot-trading-page__hero-stat">
              <span class="niftybot-trading-page__hero-stat-label">{{ 'Buy value'|t }}</span>
              <span class="niftybot-trading-page__hero-stat-value">₹{{ summary.total_buy_value|number_format(2) }}</span>
            </div>
            <div class="niftybot-trading-page__hero-stat">
              <span class="niftybot-trading-page__hero-stat-label">{{ 'Sell value'|t }}</span>
              <span class="niftybot-trading-page__hero-stat-value">₹{{ summary.total_sell_value|number_format(2) }}</span>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="niftybot-trading-page__hero-actions">
            <a href="{{ path('niftybot_trading.order_form') }}" class="btn btn-light">
              <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>
              {{ 'Place order'|t }}
            </a>
            <a href="{{ path('niftybot_trading.positions') }}" class="btn btn-outline-light">
              <i class="bi bi-briefcase me-2" aria-hidden="true"></i>
              {{ 'Open positions'|t }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
      <div class="niftybot-trading-page__stat-card">
        <div class="niftybot-trading-page__stat-card-top">
          <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--trades" aria-hidden="true">
            <i class="bi bi-list-check"></i>
          </div>
        </div>
        <div class="niftybot-trading-page__stat-value">{{ summary.total_trades }}</div>
        <div class="niftybot-trading-page__stat-label">{{ 'Executed trades'|t }}</div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="niftybot-trading-page__stat-card">
        <div class="niftybot-trading-page__stat-card-top">
          <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--buy" aria-hidden="true">
            <i class="bi bi-arrow-down-circle"></i>
          </div>
        </div>
        <div class="niftybot-trading-page__stat-value">₹{{ summary.total_buy_value|number_format(0) }}</div>
        <div class="niftybot-trading-page__stat-label">{{ 'Total buy value'|t }}</div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="niftybot-trading-page__stat-card">
        <div class="niftybot-trading-page__stat-card-top">
          <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--sell" aria-hidden="true">
            <i class="bi bi-arrow-up-circle"></i>
          </div>
        </div>
        <div class="niftybot-trading-page__stat-value">₹{{ summary.total_sell_value|number_format(0) }}</div>
        <div class="niftybot-trading-page__stat-label">{{ 'Total sell value'|t }}</div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="niftybot-trading-page__stat-card">
        <div class="niftybot-trading-page__stat-card-top">
          <div class="niftybot-trading-page__stat-icon niftybot-trading-page__stat-icon--investment" aria-hidden="true">
            <i class="bi bi-graph-up-arrow"></i>
          </div>
        </div>
        <div class="niftybot-trading-page__stat-value {{ summary.net_pnl >= 0 ? 'niftybot-trading-page__pnl--positive' : 'niftybot-trading-page__pnl--negative' }}">
          {{ summary.net_pnl >= 0 ? '+' : '' }}₹{{ summary.net_pnl|number_format(0) }}
        </div>
        <div class="niftybot-trading-page__stat-label">{{ 'Net P&L'|t }}</div>
      </div>
    </div>
  </div>

  <div class="card niftybot-trading-page__table-card">
    <div class="card-header">
      <h3 class="niftybot-trading-page__table-title">
        <i class="bi bi-journal-text" aria-hidden="true"></i>
        {{ 'Trade log'|t }}
      </h3>
      <p class="niftybot-trading-page__table-subtitle">
        {{ 'Last @count executed orders'|t({'@count': trades|length}) }}
      </p>
    </div>

    {% if trades|length > 0 %}
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover nowrap mb-0 niftybot-table">
            <thead>
              <tr>
                <th scope="col">{{ 'Date'|t }}</th>
                <th scope="col">{{ 'Symbol'|t }}</th>
                <th scope="col">{{ 'Exchange'|t }}</th>
                <th scope="col">{{ 'Type'|t }}</th>
                <th scope="col">{{ 'Qty'|t }}</th>
                <th scope="col">{{ 'Price'|t }}</th>
                <th scope="col">{{ 'Value'|t }}</th>
                <th scope="col">{{ 'Broker'|t }}</th>
                <th scope="col">{{ 'Strategy'|t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for trade in trades %}
                <tr>
                  <td data-label="{{ 'Date'|t }}">{{ trade.executed_at|date('d M Y, h:i A') }}</td>
                  <td data-label="{{ 'Symbol'|t }}" class="niftybot-trading-page__symbol">{{ trade.symbol }}</td>
                  <td data-label="{{ 'Exchange'|t }}">{{ trade.exchange }}</td>
                  <td data-label="{{ 'Type'|t }}">
                    <span class="niftybot-trading-page__txn-badge niftybot-trading-page__txn-badge--{{ trade.transaction_type|lower }}">
                      {{ trade.transaction_type }}
                    </span>
                  </td>
                  <td data-label="{{ 'Qty'|t }}">{{ trade.executed_quantity }}</td>
                  <td data-label="{{ 'Price'|t }}">₹{{ trade.executed_price|number_format(2) }}</td>
                  <td data-label="{{ 'Value'|t }}">₹{{ (trade.executed_price * trade.executed_quantity)|number_format(2) }}</td>
                  <td data-label="{{ 'Broker'|t }}" class="niftybot-trading-page__broker">{{ trade.broker|capitalize }}</td>
                  <td data-label="{{ 'Strategy'|t }}" class="niftybot-trading-page__strategy">{{ trade.strategy ?: '—' }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% else %}
      <div class="card-body">
        <div class="niftybot-trading-page__empty">
          <i class="bi bi-inbox niftybot-trading-page__empty-icon" aria-hidden="true"></i>
          <h3 class="niftybot-trading-page__empty-title">{{ 'No executed trades yet'|t }}</h3>
          <p class="niftybot-trading-page__empty-text">
            {{ 'Once your orders are filled, they will appear here with full execution details.'|t }}
          </p>
          <div class="niftybot-trading-page__empty-actions">
            <a href="{{ path('niftybot_trading.order_form') }}" class="btn btn-primary">
              <i class="bi bi-plus-circle me-1" aria-hidden="true"></i>
              {{ 'Place order'|t }}
            </a>
            <a href="{{ path('niftybot_core.user_broker') }}" class="btn btn-outline-primary">
              <i class="bi bi-link-45deg me-1" aria-hidden="true"></i>
              {{ 'Connect broker'|t }}
            </a>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>
