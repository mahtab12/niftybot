/**
 * Implements hook_theme().
 */
function user_dashboard_theme($existing, $type, $theme, $path) {
  return [
    'user_dashboard' => [
      'variables' => [
        'data' => NULL,
      ],
      'template' => 'user-dashboard',
    ],
    'user_profile' => [
      'variables' => [
        'data' => NULL,
      ],
      'template' => 'user-profile',
    ],
    'node_seller_products_edit_form_frontend' => [
      'variables' => [
        'form' => NULL,
      ],
      'template' => 'node-seller-products-edit-form-frontend',
    ],
    'user_profile' => [
      'variables' => [
        'data' => NULL,
      ],
      'template' => 'user-profile',
    ],
  ];
}

/**
 * Implements hook_preprocess_page().
 */
function user_dashboard_preprocess_page(&$variables) {
  $current_path = \Drupal::service('path.current')->getPath();
  $auth_paths = ['/user/login', '/user/password', '/user/register', '/user/reset'];
  foreach ($auth_paths as $auth_path) {
    if (str_starts_with($current_path, $auth_path)) {
      return;
    }
  }

  // Check if the path contains "/user"
  if (strpos($current_path, '/user') !== FALSE || strpos($current_path, '/profile') === 0 || strpos($current_path, '/node/add') === 0 || strpos($current_path, '/product-edit') === 0) {
    // dd("COme");
    $menu_loader = \Drupal::service('user_dashboard.menu_loader');
    $dashboard_menu = $menu_loader->loadMenu('user-dashboard-menu');
    // Attach your custom library
    $variables['dashboard_menu'] = $dashboard_menu;
    $variables['#attached']['library'][] = 'user_dashboard/dashboard';
    $variables['website_name'] = \Drupal::config('system.site')->get('name');

    if (\Drupal::routeMatch()->getRouteName() == 'entity.user.canonical') {
      // Get the user entity from the route.
      $profile_user = \Drupal::routeMatch()->getParameter('user');
      
      if ($profile_user instanceof User) {
        // Get UID
        $uid = $profile_user->id();
        // Get username
        $username = $profile_user->getDisplayName();
        // You can add it to variables for Twig
        $variables['profile_user'] = $profile_user;
        $user_details = getProfileInformation($uid);
        $variables['user_details'] = $user_details;
      }
    }
    // dd($variables['address']);
    $module_handler = \Drupal::service('extension.list.module');
    $variables['mod_path'] = '/' . $module_handler->getPath('user_dashboard');
  }
}


/**
 * Implements hook_preprocess_node().
 */
function user_dashboard_preprocess_node(array &$variables) {
  // Get the node object.
  $node = $variables['node'];

  // Get the node author (user entity).
  $author = $node->getOwner();

  // Add author information to the template variables.
  $variables['author_name'] = $author->getDisplayName();
  $variables['author_uid'] = $author->id();

  //$uid = \Drupal::currentUser()->id();
  $user_details = getProfileInformation($author->id());
  $variables['user_details'] = $user_details;
  // dd($user_details);
  // Optional: Add author profile fields (example: profile picture).
  if ($author->hasField('user_picture') && !$author->get('user_picture')->isEmpty()) {
    $variables['author_picture_url'] = file_create_url($author->get('user_picture')->entity->getFileUri());
  }
  else {
    $variables['author_picture_url'] = NULL;
  }

  // Optional: Add other user-related info
  if ($author->hasField('field_company_name') && !$author->get('field_company_name')->isEmpty()) {
    $variables['author_company'] = $author->get('field_company_name')->value;
  }

  // You can now use {{ author_name }}, {{ author_picture_url }}, {{ author_company }} in node template.
}



