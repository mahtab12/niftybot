/**
 * Get formatted country and state from a user's address field.
 */
function getUserAddressDetails($pid) {
  // dd($uid);
  $account = Profile::load($pid);
  if (!$account || !$account->hasField('field_address')) {
    return [];
  }

  $address = $account->get('field_address')->first();
  if (!$address) {
    return [];
  }
  //dd($address);
  $city = $address->get('locality')->getString();
  $state_code   = $address->get('administrative_area')->getString();
  $country_code = $address->get('country_code')->getString();
  
  $country_repo = new CountryRepository();

  // Get country name
  $country_name = '';
  if ($country_code) {
    $country = $country_repo->get($country_code);
    if ($country) {
      $country_name = $country->getName();
    }
  }

  return [
    'country_code' => $country_code,
    'country_name' => $country_name,
    'state_code'   => $state_code,
    'state_name'   => $state_code,
    'city'         => $city,
  ];
}


/**
 * Implements hook_page_attachments_alter().
 */
function user_dashboard_page_attachments_alter(array &$attachments) {
  // Get current route.
  $route_name = \Drupal::routeMatch()->getRouteName();
  // dd($route_name);
  // Example: Remove library only on the node page of type 'article'.
  if ($route_name === 'entity.user.canonical' || $route_name == 'user_dashboard.user_profile_edit') {
    $user = \Drupal::routeMatch()->getParameter('user');
    if ($user) {
      // dd("Here");
      if (isset($attachments['#attached']['library'])) {
        $attachments['#attached']['library'] = array_diff(
          $attachments['#attached']['library'],
          ['martis/bootstrap'] // Replace with your library.
        );
      }
    }
  }
  if ($route_name == "user_dashboard.user_profile_edit") {
    if (isset($attachments['#attached']['library'])) {
        $attachments['#attached']['library'] = array_diff(
        $attachments['#attached']['library'],
        ['martis/niceselect'] // Replace with your library.
      );
    }
  }
}

function user_dashboard_preprocess_form(&$variables) {
  if ($variables['element']['#id'] == 'mobile-register-form') {
    $variables['theme_hook_suggestions'][] = 'form__mobile_register_form';
  }
}

function user_dashboard_preprocess_form__mobile_register_form(&$variables) {
  // Add a class or debug variable
  $variables['attributes']['class'][] = 'custom-mobile-register-form';
  // Or add a test variable
  $variables['my_test'] = 'template working';
}