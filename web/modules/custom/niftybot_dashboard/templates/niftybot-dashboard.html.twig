<div class="niftybot-dashboard">
  {# Alerts Section #}
  {% if kyc_status != 'approved' %}
    <div class="dashboard-alert alert--warning">
      {% if kyc_status == 'not_submitted' %}
        {{ 'KYC verification is required before trading.'|t }}
        <a href="{{ path('niftybot_user.kyc_submit') }}">{{ 'Complete KYC'|t }}</a>
      {% elseif kyc_status == 'pending' or kyc_status == 'under_review' %}
        {{ 'Your KYC is under review. You will be notified once approved.'|t }}
      {% elseif kyc_status == 'rejected' %}
        {{ 'Your KYC was rejected.'|t }}
        <a href="{{ path('niftybot_user.kyc_submit') }}">{{ 'Re-submit'|t }}</a>
      {% endif %}
    </div>
  {% endif %}

  {% if not subscription %}
    <div class="dashboard-alert alert--info">
      {{ 'No active subscription.'|t }}
      <a href="{{ path('niftybot_subscription.plans') }}">{{ 'Subscribe now'|t }}</a>
    </div>
  {% endif %}

  {# Stats Cards #}
  <div class="dashboard-stats">
    <div class="stat-card">
      <div class="stat-icon">💰</div>
      <div class="stat-content">
        <div class="stat-value">₹{{ wallet_balance|number_format(2) }}</div>
        <div class="stat-label">{{ 'Wallet Balance'|t }}</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon">📊</div>
      <div class="stat-content">
        <div class="stat-value">{{ stats.open_positions }}</div>
        <div class="stat-label">{{ 'Open Positions'|t }}</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon">📋</div>
      <div class="stat-content">
        <div class="stat-value">{{ stats.orders_today }}</div>
        <div class="stat-label">{{ 'Orders Today'|t }}</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon">{{ stats.total_pnl >= 0 ? '📈' : '📉' }}</div>
      <div class="stat-content">
        <div class="stat-value {{ stats.total_pnl >= 0 ? 'pnl-positive' : 'pnl-negative' }}">
          {{ stats.total_pnl >= 0 ? '+' : '' }}₹{{ stats.total_pnl|number_format(2) }}
        </div>
        <div class="stat-label">{{ 'Total P&L'|t }}</div>
      </div>
    </div>
  </div>

  {# Subscription Info #}
  {% if subscription and plan %}
    <div class="dashboard-subscription-bar">
      <span>{{ 'Plan:'|t }} <strong>{{ plan.name }}</strong></span>
      <span>{{ 'Expires:'|t }} {{ subscription.end_date|date('d M Y') }}</span>
      <span>{{ 'Max Orders/Day:'|t }} {{ plan.max_orders_per_day }}</span>
    </div>
  {% endif %}

  <div class="dashboard-grid">
    {# Quick Actions #}
    <div class="dashboard-card quick-actions">
      <h3>{{ 'Quick Actions'|t }}</h3>
      <div class="action-buttons">
        <a href="{{ path('niftybot_trading.order_form') }}" class="button button--primary">{{ 'Place Order'|t }}</a>
        <a href="{{ path('niftybot_user.wallet_deposit') }}" class="button">{{ 'Deposit'|t }}</a>
        <a href="{{ path('niftybot_trading.positions') }}" class="button">{{ 'Positions'|t }}</a>
        <a href="{{ path('niftybot_trading.history') }}" class="button">{{ 'History'|t }}</a>
        <a href="{{ path('niftybot_reports.user') }}" class="button">{{ 'Reports'|t }}</a>
      </div>
    </div>

    {# Open Positions #}
    <div class="dashboard-card positions-card">
      <h3>{{ 'Open Positions'|t }}</h3>
      {% if positions|length > 0 %}
        <table class="niftybot-table compact">
          <thead>
            <tr>
              <th>{{ 'Symbol'|t }}</th>
              <th>{{ 'Qty'|t }}</th>
              <th>{{ 'Avg'|t }}</th>
              <th>{{ 'P&L'|t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for pos in positions %}
              <tr>
                <td>{{ pos.symbol }}</td>
                <td>{{ pos.quantity }}</td>
                <td>₹{{ pos.average_price|number_format(2) }}</td>
                <td class="{{ pos.pnl >= 0 ? 'pnl-positive' : 'pnl-negative' }}">
                  {{ pos.pnl >= 0 ? '+' : '' }}₹{{ pos.pnl|number_format(2) }}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
        <a href="{{ path('niftybot_trading.positions') }}" class="view-all">{{ 'View All'|t }} →</a>
      {% else %}
        <p class="empty-state-small">{{ 'No open positions.'|t }}</p>
      {% endif %}
    </div>

    {# Recent Orders #}
    <div class="dashboard-card orders-card">
      <h3>{{ 'Recent Orders'|t }}</h3>
      {% if recent_orders|length > 0 %}
        <table class="niftybot-table compact">
          <thead>
            <tr>
              <th>{{ 'Symbol'|t }}</th>
              <th>{{ 'Type'|t }}</th>
              <th>{{ 'Qty'|t }}</th>
              <th>{{ 'Status'|t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for order in recent_orders %}
              <tr>
                <td>{{ order.symbol }}</td>
                <td>
                  <span class="txn-type txn-type--{{ order.transaction_type|lower }}">
                    {{ order.transaction_type }}
                  </span>
                </td>
                <td>{{ order.quantity }}</td>
                <td>
                  <span class="order-status order-status--{{ order.status }}">
                    {{ order.status|replace({'_': ' '})|capitalize }}
                  </span>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
        <a href="{{ path('niftybot_trading.orders') }}" class="view-all">{{ 'View All Orders'|t }} →</a>
      {% else %}
        <p class="empty-state-small">{{ 'No orders placed yet.'|t }}</p>
      {% endif %}
    </div>
  </div>
</div>
