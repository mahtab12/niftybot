<?php

/**
 * @file
 * Primary module hooks for NiftyBot Dashboard module.
 */

/**
 * Implements hook_theme().
 */
function niftybot_dashboard_theme($existing, $type, $theme, $path) {
  return [
    'niftybot_dashboard' => [
      'variables' => [
        'user' => NULL,
        'display_name' => '',
        'member_id' => NULL,
        'phone' => '',
        'city' => '',
        'kyc_status' => NULL,
        'subscription' => NULL,
        'plan' => NULL,
        'wallet_balance' => 0,
        'available_balance' => 0,
        'wallet_totals' => ['deposits' => 0, 'withdrawals' => 0],
        'positions' => [],
        'recent_orders' => [],
        'stats' => [],
        'fxc_investment' => NULL,
        'investment_principal' => 0,
        'investment_profit_pending' => 0,
        'investment_profit_total' => 0,
        'broker' => [],
      ],
      'template' => 'niftybot-dashboard',
    ],
  ];
}
