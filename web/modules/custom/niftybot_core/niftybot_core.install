        'type' => 'varchar',
        'length' => 80,
        'not null' => TRUE,
      ],
      'exchange' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => TRUE,
      ],
      'strike' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 2,
        'not null' => FALSE,
      ],
      'expiry_date' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => FALSE,
      ],
      'quantity' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
      'entry_price' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 4,
        'not null' => FALSE,
      ],
      'exit_price' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 4,
        'not null' => FALSE,
      ],
      'current_price' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 4,
        'not null' => FALSE,
      ],
      'stop_loss' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 4,
        'not null' => FALSE,
      ],
      'target' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 4,
        'not null' => FALSE,
      ],
      'sl_points' => [
        'type' => 'numeric',
        'precision' => 8,
        'scale' => 2,
        'not null' => FALSE,
      ],
      'target_points' => [
        'type' => 'numeric',
        'precision' => 8,
        'scale' => 2,
        'not null' => FALSE,
      ],
      'pnl' => [
        'type' => 'numeric',
        'precision' => 15,
        'scale' => 2,
        'not null' => FALSE,
        'default' => 0,
      ],
      'pnl_percentage' => [
        'type' => 'numeric',
        'precision' => 8,
        'scale' => 2,
        'not null' => FALSE,
        'default' => 0,
      ],
      'underlying_ltp_at_entry' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 2,
        'not null' => FALSE,
      ],
      'broker_order_id' => [
        'type' => 'varchar',
        'length' => 100,
        'not null' => FALSE,
      ],
      'exit_broker_order_id' => [
        'type' => 'varchar',
        'length' => 100,
        'not null' => FALSE,
      ],
      'smart_order_id' => [
        'type' => 'varchar',
        'length' => 100,
        'not null' => FALSE,
      ],
      'smart_order_status' => [
        'type' => 'varchar',
        'length' => 30,
        'not null' => FALSE,
      ],
      'signal_action' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => FALSE,
      ],
      'signal_confidence' => [
        'type' => 'numeric',
        'precision' => 6,
        'scale' => 4,
        'not null' => FALSE,
      ],
      'signal_reasons' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
        'description' => 'JSON array of signal reasons.',
      ],
      'signal_indicators' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
        'description' => 'JSON object of indicator values at entry.',
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
        'default' => 'open',
        'description' => 'open, closed.',
      ],
      'exit_reason' => [
        'type' => 'varchar',
        'length' => 50,
        'not null' => FALSE,
      ],
      'recovered_from_broker' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
      ],
      'opened_at' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'closed_at' => [
        'type' => 'int',
        'not null' => FALSE,
      ],
      'updated' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['record_id'],
    'unique keys' => [
      'trade_id' => ['trade_id'],
