        'not null' => FALSE,
      ],
      'profile_data' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
        'description' => 'Serialized JSON profile snapshot.',
      ],
      'last_verified' => [
        'type' => 'int',
        'not null' => FALSE,
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'updated' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['connection_id'],
    'unique keys' => [
      'uid_broker' => ['uid', 'broker'],
    ],
    'indexes' => [
      'uid' => ['uid'],
      'status' => ['status'],
    ],
  ];

  $schema['niftybot_trade_alerts'] = [
    'description' => 'Platform trade-setup alerts broadcast to all traders.',
    'fields' => [
      'alert_id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'instrument' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
      ],
      'signal_action' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
      ],
      'confidence' => [
        'type' => 'numeric',
        'precision' => 6,
        'scale' => 4,
        'not null' => FALSE,
      ],
      'title' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
      ],
      'message' => [
        'type' => 'text',
        'not null' => TRUE,
      ],
      'underlying_ltp' => [
        'type' => 'numeric',
        'precision' => 12,
        'scale' => 2,
        'not null' => FALSE,
      ],
      'payload' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['alert_id'],
    'indexes' => [
      'instrument_created' => ['instrument', 'created'],
      'signal_action' => ['signal_action'],
    ],
  ];

  $schema['niftybot_user_notification_reads'] = [
    'description' => 'Per-user read state for platform trade alerts.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'uid' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'alert_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'read_at' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'uid_alert' => ['uid', 'alert_id'],
    ],
    'indexes' => [
      'uid' => ['uid'],
