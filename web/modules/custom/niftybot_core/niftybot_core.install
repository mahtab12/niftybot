/**
 * User auto-trade quantity preferences (per instrument).
 */
function niftybot_core_user_auto_trade_settings_schema(): array {
  return [
    'description' => 'Per-user auto-trade quantity and billing preferences.',
    'fields' => [
      'uid' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'nifty_quantity' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 65,
      ],
      'sensex_quantity' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 20,
      ],
      'updated' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['uid'],
  ];
}

/**
 * Log of per-trade algo fees charged from wallet.
 */
function niftybot_core_user_auto_trade_fees_schema(): array {
  return [
    'description' => 'Pay-per-trade algo fees debited from user wallets.',
    'fields' => [
      'fee_id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'uid' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'instrument' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
      ],
      'trade_id' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
      ],
      'amount' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
        'not null' => TRUE,
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['fee_id'],
    'indexes' => [
      'uid' => ['uid'],
      'trade_id' => ['trade_id'],
    ],
  ];
}

/**
 * Create auto-trades table for existing sites.
 */
function niftybot_core_update_9001() {
  $schema = niftybot_core_schema();
  if (!\Drupal::database()->schema()->tableExists('niftybot_auto_trades')) {
    \Drupal::database()->schema()->createTable(
      'niftybot_auto_trades',
      $schema['niftybot_auto_trades'],
    );
  }
}

/**
 * Create per-user broker connections table.
 */
function niftybot_core_update_9002() {
  $schema = niftybot_core_schema();
  if (!\Drupal::database()->schema()->tableExists('niftybot_broker_connections')) {
    \Drupal::database()->schema()->createTable(
      'niftybot_broker_connections',
      $schema['niftybot_broker_connections'],
    );
  }
}

/**
 * Create trade alert and in-app notification read tables.
 */
function niftybot_core_update_9003() {
  $schema = niftybot_core_schema();
  $db_schema = \Drupal::database()->schema();
  foreach (['niftybot_trade_alerts', 'niftybot_user_notification_reads'] as $table) {
    if (!$db_schema->tableExists($table)) {
      $db_schema->createTable($table, $schema[$table]);
    }
  }
}

/**
 * Create user auto-trade settings and fee log tables.
 */
function niftybot_core_update_9004() {
  $schema = niftybot_core_schema();
  $db_schema = \Drupal::database()->schema();
  foreach (['niftybot_user_auto_trade_settings', 'niftybot_user_auto_trade_fees'] as $table) {
    if (!$db_schema->tableExists($table)) {
      $db_schema->createTable($table, $schema[$table]);
    }
  }
}
