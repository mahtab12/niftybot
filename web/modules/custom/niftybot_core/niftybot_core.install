      'position_side' => [
        'type' => 'varchar',
        'length' => 10,
        'not null' => TRUE,
        'default' => 'long',
        'description' => 'long or short.',
      ],
      'option_type' => [
        'type' => 'varchar',
        'length' => 4,
        'not null' => TRUE,
        'description' => 'CE or PE.',
      ],
