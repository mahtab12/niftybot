      'status_message' => [
        'type' => 'varchar',
        'length' => 512,
        'not null' => FALSE,
      ],
      'broker_user_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => FALSE,
      ],
      'ucc' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => FALSE,
      ],
      'balance' => [
        'type' => 'numeric',
        'precision' => 14,
