<div class="niftybot-auto-trade-overview">
  <div class="card niftybot-auto-trade-overview__hero mb-4">
    <div class="card-body">
      <div class="d-flex align-items-start gap-3">
        <div class="niftybot-auto-trade-overview__icon" aria-hidden="true">
          <i class="bi bi-robot"></i>
        </div>
        <div>
          <h2 class="niftybot-auto-trade-overview__title">{{ 'Auto Trade'|t }}</h2>
          <p class="niftybot-auto-trade-overview__lead">
            {{ 'Automated trading on Groww for Nifty and Sensex index options (CASH and F&O). Groww APIs do not support MCX commodity orders at this time.'|t }}
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="niftybot-auto-trade-overview__layout">
    <div class="card niftybot-auto-trade-overview__card">
      <div class="card-body">
        <h3>{{ 'How it works'|t }}</h3>
        <ol class="niftybot-auto-trade-overview__steps">
          <li>{{ 'Connect your personal Groww account (API key & secret).'|t }}</li>
          <li>{{ 'Subscribe monthly, or keep at least ₹100 in your wallet for pay-per-trade (₹100 per executed algo trade).'|t }}</li>
          <li>{{ 'Set your trade quantity per instrument (see lot sizes on each page).'|t }}</li>
          <li>{{ 'Open an auto-trade page and choose buying or selling mode.'|t }}</li>
          <li>{{ 'Activate — the engine monitors live signals and places one trade per session.'|t }}</li>
          <li>{{ 'Stop-loss and target are managed via OCO smart orders on Groww.'|t }}</li>
        </ol>

        <h4 class="mt-4 mb-2">{{ 'Before you start'|t }}</h4>
        <ul class="niftybot-auto-trade-overview__list">
          <li>{{ 'Keep sufficient F&O margin in your Groww account.'|t }}</li>
          <li>{{ 'Auto-trade runs during market hours only.'|t }}</li>
          <li>{{ 'You can deactivate or exit an open position anytime.'|t }}</li>
        </ul>

        <div class="mt-4">
          <a href="{{ path('niftybot_core.user_broker') }}" class="btn btn-outline-primary">
            <i class="bi bi-plug me-1" aria-hidden="true"></i>{{ 'Connect broker'|t }}
          </a>
        </div>
      </div>
    </div>

    <div class="card niftybot-auto-trade-overview__card">
      <div class="card-body">
        <h3>{{ 'Index options (NSE / BSE)'|t }}</h3>
        <p class="text-secondary small mb-3">{{ 'Weekly index options with OCO smart orders on Groww.'|t }}</p>

        <a href="{{ path('niftybot_core.user_auto_trade_nifty') }}" class="niftybot-auto-trade-overview__link-card">
          <span class="niftybot-auto-trade-overview__link-icon" aria-hidden="true"><i class="bi bi-graph-up"></i></span>
          <span>
            <strong>{{ 'Nifty Auto Trade'|t }}</strong>
            <small>{{ 'Nifty 50 options · 1 lot (65 qty)'|t }}</small>
          </span>
          <i class="bi bi-chevron-right" aria-hidden="true"></i>
        </a>

        <a href="{{ path('niftybot_core.user_auto_trade_sensex') }}" class="niftybot-auto-trade-overview__link-card">
          <span class="niftybot-auto-trade-overview__link-icon" aria-hidden="true"><i class="bi bi-bar-chart-line"></i></span>
          <span>
            <strong>{{ 'Sensex Auto Trade'|t }}</strong>
            <small>{{ 'Sensex options · 1 lot (20 qty)'|t }}</small>
          </span>
          <i class="bi bi-chevron-right" aria-hidden="true"></i>
        </a>

        <h3 class="mt-4">{{ 'MCX commodities'|t }}</h3>
        <p class="text-secondary small mb-3">{{ 'Crude oil and gold auto-trade is not available — Groww Trading APIs support CASH and F&O only.'|t }}</p>

        <div class="niftybot-auto-trade-overview__link-card niftybot-auto-trade-overview__link-card--disabled" aria-disabled="true">
          <span class="niftybot-auto-trade-overview__link-icon" aria-hidden="true"><i class="bi bi-droplet-half"></i></span>
          <span>
            <strong>{{ 'Crude Oil Auto Trade'|t }}</strong>
            <small>{{ 'Unavailable on Groww API · 1 lot (10 qty)'|t }}</small>
          </span>
          <span class="badge bg-secondary">{{ 'Not supported'|t }}</span>
        </div>

        <div class="niftybot-auto-trade-overview__link-card niftybot-auto-trade-overview__link-card--disabled mt-2" aria-disabled="true">
          <span class="niftybot-auto-trade-overview__link-icon" aria-hidden="true"><i class="bi bi-gem"></i></span>
          <span>
            <strong>{{ 'Gold Auto Trade'|t }}</strong>
            <small>{{ 'Unavailable on Groww API · 1 lot (100 qty)'|t }}</small>
          </span>
          <span class="badge bg-secondary">{{ 'Not supported'|t }}</span>
        </div>
      </div>
    </div>
  </div>
</div>
