<?php

/**
 * @file
 * Primary module hooks for NiftyBot Core module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function niftybot_core_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.niftybot_core':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('NiftyBot is a trading platform that enables users to manage portfolios, place orders, and track trades through integrated broker APIs.') . '</p>';
      return $output;
  }
}

