/**
 * Implements hook_form_FORM_ID_alter() for login redirect to dashboard.
 */
function niftybot_core_form_user_login_form_alter(array &$form, FormStateInterface $form_state): void {
  $form['#submit'][] = 'niftybot_core_user_login_dashboard_redirect';
}

/**
 * Redirects users to the trading dashboard after successful login.
 */
function niftybot_core_user_login_dashboard_redirect(array &$form, FormStateInterface $form_state): void {
  if ($form_state->getErrors()) {
    return;
  }

  $destination = \Drupal::request()->query->get('destination');
  if (is_string($destination) && $destination !== '' && $destination !== '/user/login') {
    return;
  }

  $form_state->setRedirect('niftybot_dashboard.main');
}
