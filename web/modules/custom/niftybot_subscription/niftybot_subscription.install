<?php

/**
 * @file
 * Install, update and uninstall functions for niftybot_subscription module.
 */

/**
 * Implements hook_schema().
 */
function niftybot_subscription_schema() {
  $schema['niftybot_subscription_plans'] = [
    'description' => 'Subscription plans available on the platform.',
    'fields' => [
      'plan_id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
      ],
      'machine_name' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
      ],
      'description' => [
        'type' => 'text',
        'not null' => FALSE,
      ],
      'price' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
        'not null' => TRUE,
      ],
      'duration_days' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 30,
        'description' => 'Duration in days.',
      ],
      'max_orders_per_day' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 10,
      ],
      'max_capital' => [
        'type' => 'numeric',
        'precision' => 15,
        'scale' => 2,
        'not null' => FALSE,
        'description' => 'Maximum trading capital allowed.',
      ],
      'features' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => FALSE,
        'description' => 'JSON-encoded features list.',
      ],
      'brokers_allowed' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'description' => 'Comma-separated broker IDs allowed.',
      ],
      'status' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 1,
        'description' => '1 = active, 0 = inactive.',
      ],
      'weight' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Sort weight for display order.',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
      'updated' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['plan_id'],
    'unique keys' => [
      'machine_name' => ['machine_name'],
    ],
    'indexes' => [
      'status' => ['status'],
      'weight' => ['weight'],
    ],
  ];

  $schema['niftybot_user_subscriptions'] = [
    'description' => 'User subscription records.',
    'fields' => [
      'subscription_id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'uid' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'plan_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'start_date' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
      'end_date' => [
        'type' => 'int',
        'not null' => TRUE,
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => TRUE,
        'default' => 'active',
        'description' => 'Status: active, expired, cancelled.',
      ],
      'payment_amount' => [
        'type' => 'numeric',
        'precision' => 10,
        'scale' => 2,
        'not null' => TRUE,
      ],
      'payment_reference' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
      ],
      'auto_renew' => [
        'type' => 'int',
        'size' => 'tiny',
        'not null' => TRUE,
        'default' => 0,
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['subscription_id'],
    'indexes' => [
      'uid' => ['uid'],
      'plan_id' => ['plan_id'],
      'status' => ['status'],
      'end_date' => ['end_date'],
    ],
    'foreign keys' => [
      'user' => [
        'table' => 'users',
        'columns' => ['uid' => 'uid'],
      ],
      'plan' => [
        'table' => 'niftybot_subscription_plans',
        'columns' => ['plan_id' => 'plan_id'],
      ],
    ],
  ];

  return $schema;
}

/**
 * Default subscription plan definitions.
 */
