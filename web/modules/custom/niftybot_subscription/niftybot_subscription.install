  return [
    'starter' => [
      'name' => 'Starter',
      'machine_name' => 'starter',
      'description' => 'Essential auto-trade access for getting started with index options.',
      'price' => 4999.00,
      'duration_days' => 30,
      'max_orders_per_day' => 5,
      'max_capital' => 250000.00,
      'features' => json_encode([
        'Nifty & Sensex auto-trade',
        'Up to 5 auto-trades per day',
        'Live signal dashboard',
        'OCO stop-loss & target on Groww',
        'Portfolio & order history',
        'Email support',
      ]),
      'brokers_allowed' => 'groww',
      'status' => 1,
      'weight' => 0,
      'created' => $now,
      'updated' => $now,
    ],
    'pro' => [
      'name' => 'Pro',
      'machine_name' => 'pro',
      'description' => 'For active traders who need higher daily auto-trade capacity.',
      'price' => 8999.00,
      'duration_days' => 30,
      'max_orders_per_day' => 10,
      'max_capital' => 1000000.00,
      'features' => json_encode([
        'Everything in Starter',
        'Up to 10 auto-trades per day',
        'Custom trade quantity per index',
        'Advanced trade reports',
        'Priority email support',
      ]),
      'brokers_allowed' => 'groww',
      'status' => 1,
      'weight' => 1,
      'created' => $now,
      'updated' => $now,
    ],
    'elite' => [
      'name' => 'Elite',
      'machine_name' => 'elite',
      'description' => 'Maximum daily auto-trade capacity for serious index options traders.',
      'price' => 14999.00,
      'duration_days' => 30,
      'max_orders_per_day' => 25,
      'max_capital' => 5000000.00,
      'features' => json_encode([
        'Everything in Pro',
        'Up to 25 auto-trades per day',
        'Highest capital limits',
        'Dedicated priority support',
        'Early access to new strategies',
      ]),
