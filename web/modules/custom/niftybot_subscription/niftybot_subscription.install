}

/**
 * Implements hook_install().
 */
function niftybot_subscription_install() {
  $database = \Drupal::database();

  foreach (niftybot_subscription_default_plans() as $plan) {
    $database->insert('niftybot_subscription_plans')
      ->fields($plan)
      ->execute();
  }
}

/**
 * Update subscription plan pricing and daily trade limits.
 */
function niftybot_subscription_update_9001() {
  $database = \Drupal::database();
  $now = \Drupal::time()->getRequestTime();

  foreach (niftybot_subscription_default_plans() as $machine_name => $plan) {
    unset($plan['machine_name'], $plan['created']);
    $plan['updated'] = $now;

    $exists = $database->select('niftybot_subscription_plans', 'sp')
      ->fields('sp', ['plan_id'])
      ->condition('machine_name', $machine_name)
      ->execute()
      ->fetchField();

    if ($exists) {
      $database->update('niftybot_subscription_plans')
        ->fields($plan)
        ->condition('machine_name', $machine_name)
        ->execute();
    }
    else {
      $plan['machine_name'] = $machine_name;
      $plan['created'] = $now;
      $database->insert('niftybot_subscription_plans')
        ->fields($plan)
        ->execute();
    }
  }
}

/**
 * Starter plan: 5 auto-trades per day.
 */
function niftybot_subscription_update_9002() {
  $database = \Drupal::database();
  $now = \Drupal::time()->getRequestTime();
  $starter = niftybot_subscription_default_plans()['starter'];

  $database->update('niftybot_subscription_plans')
    ->fields([
      'max_orders_per_day' => 5,
      'features' => $starter['features'],
      'updated' => $now,
    ])
    ->condition('machine_name', 'starter')
    ->execute();
}
