{#
/**
 * @file
 * Subscription plans — compact pricing cards.
 */
#}
<div class="niftybot-plans-page niftybot-dashboard">
  <div class="niftybot-plans-page__header">
    <h2 class="niftybot-plans-page__title">{{ 'Choose your plan'|t }}</h2>
    <p class="niftybot-plans-page__subtitle">
      {{ 'Pick the plan that fits your trading style. Switch anytime from your dashboard.'|t }}
    </p>
  </div>

  {% if plans|length > 0 %}
    <div class="niftybot-plans-page__grid">
      {% for plan in plans %}
        {% set is_featured = plan.machine_name == 'pro' %}
        {% set is_current = current_subscription and current_subscription.plan_id == plan.plan_id %}

        <article class="niftybot-plans-card niftybot-plans-card--{{ plan.machine_name|clean_class }}{% if is_featured %} niftybot-plans-card--featured{% endif %}">
          {% if is_featured %}
            <span class="niftybot-plans-card__badge">{{ 'Popular'|t }}</span>
          {% endif %}

          <div class="niftybot-plans-card__header">
            <h3 class="niftybot-plans-card__name">{{ plan.name }}</h3>
            <div class="niftybot-plans-card__price-row">
              <span class="niftybot-plans-card__price">₹{{ plan.price|number_format(0) }}</span>
              <span class="niftybot-plans-card__period">/ {{ plan.duration_days }} {{ 'days'|t }}</span>
            </div>
          </div>

          <div class="niftybot-plans-card__body">
            {% if plan.description %}
              <p class="niftybot-plans-card__desc">{{ plan.description }}</p>
            {% endif %}

            <ul class="niftybot-plans-card__features list-unstyled mb-0">
              {% if plan.max_orders_per_day > 0 %}
                <li class="niftybot-plans-card__highlight">
                  <i class="bi bi-lightning-charge" aria-hidden="true"></i>
                  {{ '@count trades/day'|t({'@count': plan.max_orders_per_day}) }}
                </li>
              {% else %}
                <li class="niftybot-plans-card__highlight">
                  <i class="bi bi-infinity" aria-hidden="true"></i>
                  {{ 'Unlimited monthly auto-trades'|t }}
                </li>
              {% endif %}
              {% if plan.max_capital %}
                <li class="niftybot-plans-card__highlight">
                  <i class="bi bi-wallet2" aria-hidden="true"></i>
                  {{ '₹@cap max'|t({'@cap': plan.max_capital|number_format(0)}) }}
                </li>
              {% endif %}
              {% for feature in plan.features_list %}
                <li>
                  <i class="bi bi-check-lg" aria-hidden="true"></i>
                  {{ feature }}
                </li>
              {% endfor %}
            </ul>
          </div>

          <div class="niftybot-plans-card__footer">
            {% if is_current %}
              <span class="btn btn-light btn-sm disabled opacity-100 niftybot-plans-card__current w-100">
                <i class="bi bi-check-circle me-1" aria-hidden="true"></i>
                {{ 'Current plan'|t }}
              </span>
            {% else %}
              <a href="{{ path('niftybot_subscription.subscribe', {'plan_id': plan.plan_id}) }}" class="btn btn-light btn-sm w-100">
                {{ 'Subscribe'|t }}
              </a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="card niftybot-plans-empty text-center">
      <div class="card-body">
        <i class="bi bi-tags niftybot-plans-empty__icon" aria-hidden="true"></i>
        <h3 class="h6 mb-2">{{ 'No plans available'|t }}</h3>
        <p class="text-secondary mb-0 small">{{ 'Subscription plans are being updated. Please check back soon.'|t }}</p>
      </div>
    </div>
  {% endif %}
</div>
