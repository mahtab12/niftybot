      'uid' => ['uid'],
      'type' => ['type'],
      'status' => ['status'],
      'created' => ['created'],
    ],
    'foreign keys' => [
      'user' => [
        'table' => 'users',
        'columns' => ['uid' => 'uid'],
      ],
