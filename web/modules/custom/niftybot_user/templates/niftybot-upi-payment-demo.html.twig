<div class="upi-payment-demo">
  <div class="upi-qr-scanner" aria-hidden="true">
    <div class="upi-qr-scanner__frame">
      <div class="upi-qr-scanner__pattern">
        <img src="/{{ directory }}/assets/images/upi-qr.png" alt="UPI QR Code" class="upi-qr-image">
      </div>
      <div class="upi-qr-scanner__scan-line"></div>
    </div>
    <p class="upi-qr-scanner__label">{{ 'Scan to pay via UPI'|t }}</p>
  </div>

  <div class="upi-payment-details">
    <div class="upi-payment-details__row">
      <span class="upi-payment-details__label">{{ 'Amount'|t }}</span>
      <strong class="wallet-upi-amount-display upi-payment-details__value">{% if amount %}₹{{ amount|number_format(2) }}{% else %}—{% endif %}</strong>
    </div>
    <div class="upi-payment-details__row">
      <span class="upi-payment-details__label">{{ 'UPI ID'|t }}</span>
      <strong id="wallet-upi-id" class="upi-payment-details__upi">{{ upi_id }}</strong>
    </div>
    <button type="button" class="btn btn-outline-primary btn-sm wallet-upi-copy" data-upi-id="{{ upi_id }}">
      <i class="bi bi-clipboard me-1" aria-hidden="true"></i>
      {{ 'Copy UPI ID'|t }}
    </button>
  </div>
</div>
