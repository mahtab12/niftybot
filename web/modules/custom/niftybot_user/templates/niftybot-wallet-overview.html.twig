<div class="niftybot-wallet">
  <div class="niftybot-wallet__hero card mb-4">
    <div class="niftybot-wallet__hero-bg" aria-hidden="true"></div>
    <div class="card-body position-relative">
      <div class="row align-items-center g-4">
        <div class="col-lg-7">
          <div class="d-flex align-items-start gap-3">
            <div class="niftybot-wallet__icon" aria-hidden="true">
              <i class="bi bi-wallet2"></i>
            </div>
            <div>
              <p class="niftybot-wallet__label mb-2">{{ 'Wallet Balance'|t }}</p>
              <h2 class="niftybot-wallet__amount mb-0">₹{{ balance|number_format(2) }}</h2>
              <p class="niftybot-wallet__hint mb-0">{{ 'Fund your account to trade and invest'|t }}</p>
            </div>
          </div>

          {% if pending_withdrawals > 0 %}
            <div class="niftybot-wallet__meta mt-3">
              <div class="niftybot-wallet__stat">
                <span class="niftybot-wallet__stat-label">{{ 'Pending withdrawals'|t }}</span>
                <strong>₹{{ pending_withdrawals|number_format(2) }}</strong>
              </div>
              <div class="niftybot-wallet__stat">
                <span class="niftybot-wallet__stat-label">{{ 'Available to withdraw'|t }}</span>
                <strong>₹{{ available_balance|number_format(2) }}</strong>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="col-lg-5">
          <div class="niftybot-wallet__actions wallet-actions">
            <a href="{{ path('niftybot_user.wallet_deposit') }}" class="btn btn-light niftybot-wallet__btn-deposit button button--primary">
              <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>
              {{ 'Deposit'|t }}
            </a>
            <a href="{{ path('niftybot_user.wallet_withdraw') }}" class="btn btn-outline-light niftybot-wallet__btn-withdraw button">
              <i class="bi bi-arrow-up-circle me-2" aria-hidden="true"></i>
              {{ 'Withdraw'|t }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card niftybot-wallet__history-card">
    <div class="card-header space-between">
      <div>
        <h3 class="card-title mb-0">{{ 'Transaction History'|t }}</h3>
        <p class="card-subtitle mb-0">{{ 'Deposits, withdrawals, investments, and algo trade fees'|t }}</p>
      </div>
    </div>

    <div class="niftybot-wallet__filters" role="tablist" aria-label="{{ 'Filter transactions'|t }}">
      {% for option in filter_options|default([]) %}
        <a href="{{ path('niftybot_user.wallet', [], { query: { filter: option.id } }) }}"
          class="niftybot-wallet__filter{% if active_filter|default('all') == option.id %} is-active{% endif %}"
          role="tab"
          aria-selected="{{ active_filter|default('all') == option.id ? 'true' : 'false' }}">
          {{ option.label }}
        </a>
      {% endfor %}
    </div>

    {% if transactions|length > 0 %}
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover nowrap mb-0 niftybot-table wallet-transactions">
            <thead>
              <tr>
                <th scope="col">{{ 'Date'|t }}</th>
                <th scope="col">{{ 'Type'|t }}</th>
                <th scope="col">{{ 'Amount'|t }}</th>
                <th scope="col">{{ 'Method'|t }}</th>
                {% if active_filter|default('all') == 'algo_trade' %}
                  <th scope="col">{{ 'Details'|t }}</th>
                {% endif %}
                <th scope="col">{{ 'Status'|t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for txn in transactions %}
                <tr>
                  <td data-label="{{ 'Date'|t }}">{{ txn.created|date('d M Y, h:i A') }}</td>
                  <td data-label="{{ 'Type'|t }}">
                    <span class="badge {{ txn.display_badge_class }}">{{ txn.display_type_label }}</span>
                  </td>
                  <td class="txn-amount txn-amount--{{ txn.display_type }}" data-label="{{ 'Amount'|t }}">
                    {% if txn.type == 'deposit' %}+{% else %}-{% endif %}₹{{ txn.amount|number_format(2) }}
                  </td>
                  <td data-label="{{ 'Method'|t }}">{{ txn.display_method_label }}</td>
                  {% if active_filter|default('all') == 'algo_trade' %}
                    <td data-label="{{ 'Details'|t }}">
                      {% if txn.notes %}
                        {{ txn.notes }}
                      {% elseif txn.payment_reference %}
                        {{ 'Trade @id'|t({'@id': txn.payment_reference}) }}
                      {% else %}
                        —
                      {% endif %}
                    </td>
                  {% endif %}
                  <td data-label="{{ 'Status'|t }}">
                    {% if txn.status == 'completed' %}
                      <span class="badge shade-light-green green">{{ 'Completed'|t }}</span>
                    {% elseif txn.status == 'pending' and txn.type == 'deposit' %}
                      <span class="badge shade-light-yellow yellow">{{ 'Awaiting verification'|t }}</span>
                    {% elseif txn.status == 'pending' and txn.type == 'withdrawal' %}
                      <span class="badge shade-light-yellow yellow">{{ 'Awaiting approval'|t }}</span>
                    {% elseif txn.status == 'rejected' %}
                      <span class="badge shade-light-red red">{{ 'Rejected'|t }}</span>
                    {% else %}
                      <span class="badge shade-light-secondary">{{ txn.status|capitalize }}</span>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% else %}
      <div class="card-body">
        <div class="niftybot-wallet__empty text-center py-4">
          <i class="bi bi-receipt-cutoff niftybot-wallet__empty-icon" aria-hidden="true"></i>
          {% if active_filter|default('all') == 'algo_trade' %}
            <p class="mb-0">{{ 'No algo trade fees yet. Fees are charged after each executed auto-trade when you are on pay-per-trade billing.'|t }}</p>
          {% elseif active_filter|default('all') != 'all' %}
            <p class="mb-0">{{ 'No transactions match this filter.'|t }}</p>
          {% else %}
            <p class="mb-3">{{ 'No transactions yet. Make your first deposit to start trading.'|t }}</p>
            <a href="{{ path('niftybot_user.wallet_deposit') }}" class="btn btn-primary">
              <i class="bi bi-plus-circle me-1" aria-hidden="true"></i>
              {{ 'Make a deposit'|t }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
