<?php

/**
 * @file
 * Primary module hooks for NiftyBot User module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function niftybot_user_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.niftybot_user') {
    return '<p>' . t('Manages user registration, KYC verification, and wallet for the NiftyBot trading platform.') . '</p>';
  }
}

/**
 * Implements hook_theme().
 */
function niftybot_user_theme($existing, $type, $theme, $path) {
  return [
    'niftybot_user_profile' => [
      'variables' => [
        'user' => NULL,
        'kyc_status' => NULL,
        'wallet_balance' => 0,
        'subscription' => NULL,
        'member_id' => NULL,
      ],
      'template' => 'niftybot-user-profile',
    ],
    'niftybot_kyc_status' => [
      'variables' => [
        'kyc' => NULL,
        'status_label' => '',
      ],
      'template' => 'niftybot-kyc-status',
    ],
    'niftybot_wallet_overview' => [
      'variables' => [
        'balance' => 0,
        'available_balance' => 0,
        'pending_withdrawals' => 0,
        'transactions' => [],
      ],
      'template' => 'niftybot-wallet-overview',
    ],
    'niftybot_kyc_admin_list' => [
      'variables' => [
        'kyc_records' => [],
      ],
      'template' => 'niftybot-kyc-admin-list',
    ],
    'niftybot_upi_payment_demo' => [
      'variables' => [
        'upi_id' => '',
        'amount' => NULL,
      ],
      'template' => 'niftybot-upi-payment-demo',
    ],
    'niftybot_wallet_deposits_admin' => [
      'variables' => [
        'deposits' => [],
      ],
      'template' => 'niftybot-wallet-deposits-admin',
    ],
    'niftybot_wallet_withdrawals_admin' => [
      'variables' => [
        'withdrawals' => [],
      ],
      'template' => 'niftybot-wallet-withdrawals-admin',
    ],
  ];
}

/**
 * Implements hook_mail().
 */
function niftybot_user_mail($key, &$message, $params) {
  if ($key === 'notification') {
    $message['subject'] = $params['subject'];
    $message['body'][] = $params['message'];
  }
}

/**
 * Ensures KYC document upload directories exist under the private files path.
 */
function niftybot_user_ensure_kyc_upload_directories(): void {
  if (!\Drupal\Core\Site\Settings::get('file_private_path')) {
    return;
  }

  $file_system = \Drupal::service('file_system');
  $flags = \Drupal\Core\File\FileSystemInterface::CREATE_DIRECTORY | \Drupal\Core\File\FileSystemInterface::MODIFY_PERMISSIONS;
  foreach (['private://kyc/pan', 'private://kyc/aadhaar', 'private://kyc/selfie'] as $directory) {
    $file_system->prepareDirectory($directory, $flags);
  }
}

/**
 * Implements hook_user_insert().
 */
function niftybot_user_user_insert($account) {
  $database = \Drupal::database();
  $now = \Drupal::time()->getRequestTime();

  $database->insert('niftybot_wallet')
    ->fields([
      'uid' => $account->id(),
      'balance' => 0,
      'created' => $now,
      'updated' => $now,
    ])
    ->execute();

  /** @var \Drupal\niftybot_user\Service\MemberIdService $member_id_service */
  $member_id_service = \Drupal::service('niftybot_user.member_id_service');
  $member_id_service->assignMemberId((int) $account->id());
}
