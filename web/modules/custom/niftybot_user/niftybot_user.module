<?php

/**
 * @file
 * Primary module hooks for NiftyBot User module.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function niftybot_user_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.niftybot_user') {
    return '<p>' . t('Manages user registration, KYC verification, and wallet for the NiftyBot trading platform.') . '</p>';
  }
}

/**
 * Implements hook_theme().
 */
function niftybot_user_theme($existing, $type, $theme, $path) {
  return [
    'niftybot_user_profile' => [
      'variables' => [
        'user' => NULL,
        'kyc_status' => NULL,
        'wallet_balance' => 0,
        'subscription' => NULL,
      ],
      'template' => 'niftybot-user-profile',
    ],
    'niftybot_kyc_status' => [
      'variables' => [
        'kyc' => NULL,
        'status_label' => '',
      ],
      'template' => 'niftybot-kyc-status',
    ],
    'niftybot_wallet_overview' => [
      'variables' => [
        'balance' => 0,
        'transactions' => [],
      ],
      'template' => 'niftybot-wallet-overview',
    ],
    'niftybot_kyc_admin_list' => [
      'variables' => [
        'kyc_records' => [],
      ],
      'template' => 'niftybot-kyc-admin-list',
    ],
  ];
}

/**
 * Implements hook_mail().
 */
function niftybot_user_mail($key, &$message, $params) {
  if ($key === 'notification') {
    $message['subject'] = $params['subject'];
    $message['body'][] = $params['message'];
  }
}

/**
 * Implements hook_user_insert().
 */
function niftybot_user_user_insert($account) {
  $database = \Drupal::database();
  $database->insert('niftybot_wallet')
    ->fields([
      'uid' => $account->id(),
      'balance' => 0,
      'created' => \Drupal::time()->getRequestTime(),
      'updated' => \Drupal::time()->getRequestTime(),
    ])
    ->execute();
}
