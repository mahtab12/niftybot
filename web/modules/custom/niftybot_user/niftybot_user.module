<?php

/**
 * @file
 * Primary module hooks for NiftyBot User module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_form_FORM_ID_alter() for user login.
 */
function niftybot_user_form_user_login_form_alter(array &$form, FormStateInterface $form_state): void {
  array_unshift($form['#validate'], 'niftybot_user_login_form_email_validate');
  if (isset($form['name'])) {
    $form['name']['#attributes']['inputmode'] = 'email';
    $form['name']['#attributes']['autocomplete'] = 'email';
  }
}

/**
 * Maps an email address to the Drupal username before core authentication.
 */
function niftybot_user_login_form_email_validate(array &$form, FormStateInterface $form_state): void {
  $identifier = trim((string) $form_state->getValue('name'));
  if ($identifier === '') {
    return;
  }

  if (str_contains($identifier, '@')) {
    $account = user_load_by_mail($identifier);
    if ($account) {
      $form_state->setValue('name', $account->getAccountName());
    }
    return;
  }

  $member_uid = \Drupal::database()->select('niftybot_user_member_ids', 'm')
    ->fields('m', ['uid'])
    ->condition('member_id', strtoupper($identifier))
    ->execute()
    ->fetchField();

  if ($member_uid) {
    $account = \Drupal\user\Entity\User::load((int) $member_uid);
    if ($account) {
      $form_state->setValue('name', $account->getAccountName());
    }
  }
}

/**
 * Implements hook_help().
 */
function niftybot_user_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.niftybot_user') {
    return '<p>' . t('Manages user registration, KYC verification, and wallet for the NiftyBot trading platform.') . '</p>';
  }
}

