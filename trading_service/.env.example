# NiftyBot Trading Service Configuration

# API Security
API_KEY=your-drupal-to-python-api-key-here

# Groww Broker Credentials
GROWW_API_KEY=your-groww-api-key
GROWW_API_SECRET=your-groww-api-secret
GROWW_TOTP_SECRET=your-groww-totp-secret
GROWW_AUTH_METHOD=api_key  # api_key or totp

# Database (shared with Drupal - MariaDB)
DB_HOST=db
DB_PORT=3306
DB_USER=db
DB_PASSWORD=db
DB_NAME=db

# Redis (for Celery task queue)
REDIS_URL=redis://redis:6379/0

# Service Settings
LOG_LEVEL=INFO
DEBUG=false
